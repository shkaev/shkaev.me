---
import "../styles/global.css";
import ChangelogSheet from "../components/layout/ChangelogSheet.astro";
import SiteFooter from "../components/layout/SiteFooter.astro";
import SiteHead from "../components/layout/SiteHead.astro";
import SiteHeader from "../components/layout/SiteHeader.astro";
import { defaultLocale, getOtherLocale, type Locale } from "../i18n/config";
import { getSiteCopy } from "../i18n/copy";
import {
	getAlternateLocaleLinks,
	getLocaleFromPath,
	getLocaleTargetPath,
	localizePath,
	stripLocaleFromPath
} from "../i18n/routing";
import { resolveStaticAssetUrl } from "../lib/assetUrl";
import {
	shellWidthClass,
	siteUrl
} from "../lib/siteConfig";
import { normalizePath } from "../lib/sitePath";

interface Props {
	title: string;
	description?: string;
	locale?: Locale;
}

const { title, description = "Personal website of Dmitry Shkaev.", locale: explicitLocale } =
	Astro.props;

const pathname = normalizePath(Astro.url.pathname);
const locale = explicitLocale ?? getLocaleFromPath(pathname);
const copy = getSiteCopy(locale);
const basePathname = stripLocaleFromPath(pathname);
const isHomePage = basePathname === "/";
const favicon32Src = resolveStaticAssetUrl("/favicons/favicon-32.png");
const appleTouchIconSrc = resolveStaticAssetUrl("/favicons/apple-touch-icon.png");
const avatarSrc = resolveStaticAssetUrl("/avatars/avatar.jpg");
const interLatinFontSrc = "/fonts/inter-latin-variable.woff2";
const displayFontSemiboldSrc = "/fonts/ibm-plex-serif-latin-600.woff2";
const canonicalUrl = new URL(pathname, siteUrl).toString();
const socialImageUrl = new URL(avatarSrc, siteUrl).toString();
const alternateUrls = getAlternateLocaleLinks(pathname).map((item) => ({
	href: new URL(item.href, siteUrl).toString(),
	hreflang: item.locale
}));
const localizedNavigation = copy.navigation.map((item) => ({
	...item,
	href: localizePath(item.href, locale)
}));
const homeHref = localizePath("/", locale);
const languageTargetLocale = getOtherLocale(locale);
const languageTargetPath = getLocaleTargetPath(pathname, languageTargetLocale);
---

<html lang={locale}>
	<head>
		<SiteHead
			title={title}
			description={description}
			locale={locale}
			favicon32Src={favicon32Src}
			appleTouchIconSrc={appleTouchIconSrc}
			avatarSrc={avatarSrc}
			siteName={copy.siteName}
			canonicalUrl={canonicalUrl}
			socialImageUrl={socialImageUrl}
			interLatinFontSrc={interLatinFontSrc}
			displayFontSemiboldSrc={displayFontSemiboldSrc}
			alternateUrls={alternateUrls}
		/>
	</head>
	<body class="min-h-[100svh] bg-stone-50 text-stone-900 antialiased transition-colors dark:bg-stone-950 dark:text-stone-100 sm:min-h-screen">
		<div class="flex min-h-[100svh] flex-col px-6 py-6 sm:min-h-screen sm:px-8 sm:py-6 lg:px-12">
				<SiteHeader
					pathname={basePathname}
					navigation={localizedNavigation}
					avatarSrc={avatarSrc}
					siteName={copy.siteName}
					homeHref={homeHref}
					headerCopy={copy.header}
					locale={locale}
				languageTargetLocale={languageTargetLocale}
				languageTargetPath={languageTargetPath}
			/>

			<main class:list={[
				"mx-auto flex w-full flex-1 items-start",
				shellWidthClass,
				isHomePage ? "py-4 sm:py-16" : "py-6 sm:py-16"
			]}>
				<slot />
			</main>

			<SiteFooter
				isHomePage={isHomePage}
				socialLinks={copy.socialLinks}
				tagline={copy.footer.tagline}
			/>
		</div>
		<ChangelogSheet locale={locale} />
		<script is:inline>
			(() => {
				const scrollStorageKey = "scroll-position:";
				const restoreScrollFlagKey = "restore-scroll:";
				const pageKey = `${scrollStorageKey}${window.location.pathname}${window.location.search}`;
				const restoreFlagKey = `${restoreScrollFlagKey}${window.location.pathname}${window.location.search}`;

				const saveScrollPosition = () => {
					try {
						sessionStorage.setItem(pageKey, String(window.scrollY));
					} catch {
						// Ignore storage failures and keep default browser behavior.
					}
				};

				const restoreScrollPosition = () => {
					try {
						const storedPosition = sessionStorage.getItem(pageKey);

						if (storedPosition === null) {
							return;
						}

						const y = Number.parseFloat(storedPosition);

						if (!Number.isFinite(y)) {
							return;
						}

						requestAnimationFrame(() => {
							requestAnimationFrame(() => {
								window.scrollTo({ top: y, left: 0, behavior: "auto" });
							});
						});
					} catch {
						// Ignore storage failures and keep default browser behavior.
					}
				};

				const markRestoreForPath = (path) => {
					try {
						const url = new URL(path, window.location.origin);
						const key = `${restoreScrollFlagKey}${url.pathname}${url.search}`;
						sessionStorage.setItem(key, "1");
					} catch {
						// Ignore malformed targets and keep default browser behavior.
					}
				};

				if ("scrollRestoration" in history) {
					history.scrollRestoration = "manual";
				}

				window.addEventListener("pagehide", saveScrollPosition);
				document.addEventListener("visibilitychange", () => {
					if (document.visibilityState === "hidden") {
						saveScrollPosition();
					}
				});

				window.addEventListener("pageshow", (event) => {
					const navigationEntry = performance.getEntriesByType("navigation")[0];
					const navigationType = navigationEntry &&
						typeof navigationEntry === "object" &&
						"type" in navigationEntry
						? navigationEntry.type
						: "";

					const shouldRestoreViaFlag = sessionStorage.getItem(restoreFlagKey) === "1";

					if (
						event.persisted ||
						navigationType === "back_forward" ||
						shouldRestoreViaFlag
					) {
						sessionStorage.removeItem(restoreFlagKey);
						restoreScrollPosition();
					}
				});

				document.addEventListener("click", (event) => {
					const target = event.target;

					if (!(target instanceof Element)) {
						return;
					}

					const restoreLink = target.closest("[data-restore-scroll-target]");

					if (!(restoreLink instanceof HTMLAnchorElement)) {
						return;
					}

					if (
						event.defaultPrevented ||
						event.button !== 0 ||
						restoreLink.target === "_blank" ||
						event.metaKey ||
						event.ctrlKey ||
						event.shiftKey ||
						event.altKey
					) {
						return;
					}

					const restoreTarget =
						restoreLink.dataset.restoreScrollTarget || restoreLink.getAttribute("href");

					if (!restoreTarget) {
						return;
					}

					markRestoreForPath(restoreTarget);
				});
			})();
		</script>
			<script>
				import { setupThemeControls } from "../scripts/siteTheme";
				import { setupChangelogSheet } from "../scripts/changelogSheet";
				import { setupLocaleToggle } from "../scripts/siteLocaleToggle";

				setupThemeControls();
				setupChangelogSheet();
				setupLocaleToggle();
			</script>
		</body>
	</html>
