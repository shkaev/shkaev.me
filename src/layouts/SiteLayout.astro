---
import "../styles/global.css";

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Personal website of Dima Shkaev." } =
	Astro.props;

const pathname = Astro.url.pathname;

const navigation = [
	{ href: "/photography", label: "Photography" },
	{ href: "/design", label: "Design" },
	{ href: "/about", label: "About" }
];

const socialLinks = [
	{
		href: "https://www.linkedin.com/in/shkaev/",
		label: "LinkedIn"
	},
	{
		href: "https://www.instagram.com/shkaev/",
		label: "Instagram"
	}
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
	</head>
	<body class="min-h-screen bg-stone-50 text-stone-900 antialiased">
		<div class="flex min-h-screen flex-col px-6 py-6 sm:px-8 lg:px-12">
			<header class="mx-auto flex w-full max-w-[60rem] flex-col gap-6 border-b border-stone-200/80 pb-6 sm:flex-row sm:items-center sm:justify-between">
				<div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-10">
					<a
						href="/"
						aria-label="Home"
						class="flex h-14 w-14 items-center justify-center overflow-hidden rounded-full border border-stone-200 bg-white text-stone-950 transition hover:border-stone-300"
					>
						<img
							src="/avatars/avatar.jpg"
							alt="Dima Shkaev"
							class="h-full w-full object-cover"
						/>
					</a>
					<nav aria-label="Primary" class="flex flex-wrap items-center gap-x-7 gap-y-3">
						{
							navigation.map((item) => {
								const isActive = pathname === item.href;

								return (
									<a
										href={item.href}
										aria-current={isActive ? "page" : undefined}
										class:list={[
											"text-base tracking-tight transition-colors sm:text-lg",
											isActive
												? "font-medium text-stone-950"
												: "text-stone-500 hover:text-stone-900"
										]}
									>
										{item.label}
									</a>
								);
							})
						}
					</nav>
				</div>

				<div class="flex items-center gap-3">
					{
						socialLinks.map((item) => (
							<a
								href={item.href}
								target="_blank"
								rel="noreferrer"
								aria-label={item.label}
								class="flex h-11 w-11 items-center justify-center rounded-full border border-stone-200 bg-white text-stone-700 transition hover:border-stone-300 hover:text-stone-950"
							>
								{
									item.label === "LinkedIn" ? (
										<svg
											aria-hidden="true"
											viewBox="0 0 24 24"
											class="h-4.5 w-4.5 fill-current"
										>
											<path d="M6.94 8.5H3.56V20h3.38V8.5ZM5.25 3A1.97 1.97 0 0 0 3.28 5c0 1.08.88 1.94 1.94 1.94h.03A1.96 1.96 0 0 0 7.22 5 1.95 1.95 0 0 0 5.25 3Zm10.16 5.23c-1.8 0-2.6.99-3.06 1.69V8.5H8.97c.04.93 0 11.5 0 11.5h3.38v-6.42c0-.34.02-.68.13-.92.27-.68.88-1.38 1.9-1.38 1.34 0 1.88 1.03 1.88 2.54V20h3.38v-6.57c0-3.52-1.88-5.2-4.23-5.2Z"></path>
										</svg>
									) : (
										<svg
											aria-hidden="true"
											viewBox="0 0 24 24"
											class="h-4.5 w-4.5 fill-current"
										>
											<path d="M7.75 3h8.5A4.75 4.75 0 0 1 21 7.75v8.5A4.75 4.75 0 0 1 16.25 21h-8.5A4.75 4.75 0 0 1 3 16.25v-8.5A4.75 4.75 0 0 1 7.75 3Zm-.17 1.74A2.84 2.84 0 0 0 4.74 7.6v8.8a2.84 2.84 0 0 0 2.84 2.85h8.84a2.84 2.84 0 0 0 2.84-2.84V7.58a2.84 2.84 0 0 0-2.84-2.84H7.58Zm9.52 1.3a1.15 1.15 0 1 1 0 2.3 1.15 1.15 0 0 1 0-2.3ZM12 7.62A4.38 4.38 0 1 1 7.62 12 4.39 4.39 0 0 1 12 7.62Zm0 1.74A2.64 2.64 0 1 0 14.64 12 2.64 2.64 0 0 0 12 9.36Z"></path>
										</svg>
									)
								}
							</a>
						))
					}
				</div>
			</header>

			<main class="mx-auto flex w-full max-w-[60rem] flex-1 items-start py-12 sm:py-16">
				<slot />
			</main>

			<footer class="mx-auto mt-8 flex w-full max-w-[60rem] flex-col gap-2 border-t border-stone-200/80 pt-6 text-sm text-stone-500 sm:flex-row sm:items-center sm:justify-between">
				<p>Design, photography, and the things in between.</p>
				<p>Built by Dmitry Shkaev © 2026</p>
			</footer>
		</div>
	</body>
</html>
