---
import SiteLayout from "./SiteLayout.astro";
import BackLink from "../components/BackLink.astro";
import ChevronRightIcon from "../components/icons/ChevronRightIcon.astro";
import { resolveStaticAssetUrl } from "../lib/assetUrl";

interface MoreCaseStudyLink {
	href: string;
	title: string;
	logoSrc: string;
	logoAlt: string;
	imageSrc: string;
	imageAlt: string;
	description: string;
}

interface Props {
	title: string;
	description: string;
	pageTitle: string;
	heroSrc: string;
	heroAlt: string;
	moreCaseStudies: MoreCaseStudyLink[];
}

const {
	title,
	description,
	pageTitle,
	heroSrc,
	heroAlt,
	moreCaseStudies
} = Astro.props;

const resolvedHeroSrc = resolveStaticAssetUrl(heroSrc);
const resolvedMoreCaseStudies = moreCaseStudies.map((study) => ({
	...study,
	logoSrc: resolveStaticAssetUrl(study.logoSrc),
	imageSrc: resolveStaticAssetUrl(study.imageSrc)
}));
---

<SiteLayout title={title} description={description}>
	<div class="flex w-full flex-col">
		<section class="w-full">
			<BackLink href="/design" label="Case studies" />
			<h1 class="mt-6 text-4xl font-normal tracking-tight text-balance text-stone-950 sm:text-5xl md:text-6xl">
				{pageTitle}
			</h1>
			<p class="mt-5 text-base leading-8 text-stone-700 sm:text-lg">
				{description}
			</p>
		</section>

		<section class="mt-10 w-full overflow-hidden rounded-[12px] bg-white/80 shadow-[0_1px_0_rgba(28,25,23,0.04)]">
			<img
				src={resolvedHeroSrc}
				alt={heroAlt}
				class="h-auto w-full"
				loading="eager"
			/>
		</section>

		<slot />

		<section class="mt-20 w-full">
			<p class="text-sm font-medium uppercase tracking-[0.24em] text-stone-500">
				Read more case studies
			</p>
			<div class="mt-6 flex flex-col gap-4">
				{
					resolvedMoreCaseStudies.map((study) => (
						<a
							href={study.href}
							data-hover-card
							class="group grid w-full grid-cols-1 overflow-hidden rounded-[12px] border border-stone-200/70 bg-white shadow-[0_1px_0_rgba(28,25,23,0.04)] transition-colors hover:border-stone-300/80 sm:min-h-32 sm:grid-cols-[9rem_minmax(0,1fr)_2.5rem] sm:items-center sm:gap-x-7 sm:p-4"
						>
							<div class="aspect-[16/9] overflow-hidden bg-stone-100 sm:-my-4 sm:-ml-4 sm:aspect-auto sm:self-stretch">
								<img
									src={study.imageSrc}
									alt={study.imageAlt}
									class="block h-full w-full object-cover transition-transform duration-300 ease-out group-hover:scale-[1.08]"
									loading="lazy"
								/>
							</div>
							<div class="min-w-0 px-4 py-4 sm:px-0 sm:py-0">
								<h4 class="flex min-w-0 items-center gap-2 text-xl tracking-tight text-stone-950 sm:gap-2.5 sm:text-2xl">
									<img
										src={study.logoSrc}
										alt=""
										aria-hidden="true"
										loading="lazy"
										class="h-4 w-4 shrink-0 rounded-[4px] object-cover sm:h-[1.125rem] sm:w-[1.125rem]"
									/>
									<span class="truncate">{study.title}</span>
								</h4>
								<p class="mt-1 text-xs leading-5 text-stone-700 sm:text-sm">
									{study.description}
								</p>
							</div>
							<span
								data-card-accent
								class="hidden h-10 w-10 items-center justify-center self-center text-stone-400 transition group-hover:text-stone-700 sm:flex"
							>
								<ChevronRightIcon class="h-5 w-5" />
							</span>
						</a>
					))
				}
			</div>
		</section>
	</div>
</SiteLayout>
