---
import SiteLayout from "./SiteLayout.astro";
import BackLink from "../components/BackLink.astro";
import ChevronRightIcon from "../components/icons/ChevronRightIcon.astro";

interface MoreCaseStudyLink {
	href: string;
	title: string;
}

interface Props {
	title: string;
	description: string;
	pageTitle: string;
	heroSrc: string;
	heroAlt: string;
	moreCaseStudies: MoreCaseStudyLink[];
}

const {
	title,
	description,
	pageTitle,
	heroSrc,
	heroAlt,
	moreCaseStudies
} = Astro.props;
---

<SiteLayout title={title} description={description}>
	<div class="flex w-full flex-col">
		<section class="w-full">
			<BackLink href="/design" label="Case studies" />
			<h1 class="mt-6 text-4xl font-normal tracking-tight text-balance text-stone-950 sm:text-5xl md:text-6xl">
				{pageTitle}
			</h1>
			<p class="mt-5 text-base leading-8 text-stone-700 sm:text-lg">
				{description}
			</p>
		</section>

		<section class="mt-10 w-full overflow-hidden rounded-[12px] bg-white/80 shadow-[0_1px_0_rgba(28,25,23,0.04)]">
			<img
				src={heroSrc}
				alt={heroAlt}
				class="h-auto w-full"
				loading="eager"
			/>
		</section>

		<slot />

		<section class="mt-20 w-full">
			<p class="text-sm font-medium uppercase tracking-[0.24em] text-stone-500">
				View more case studies
			</p>
			<div class="mt-6 flex flex-col gap-4">
				{
					moreCaseStudies.map((study) => (
						<a
							href={study.href}
							data-hover-card
							class="group grid grid-cols-[minmax(0,1fr)_2.5rem] items-center gap-x-6 rounded-[12px] border border-stone-200/70 bg-white px-5 py-5 shadow-[0_1px_0_rgba(28,25,23,0.04)] transition-colors hover:border-stone-300/80 sm:px-6 sm:py-6"
						>
							<div class="min-w-0">
								<h4 class="text-xl tracking-tight text-stone-950 sm:text-2xl">
									{study.title}
								</h4>
							</div>
							<span
								data-card-accent
								class="flex h-10 w-10 items-center justify-center self-center text-stone-400 transition group-hover:text-stone-700"
							>
								<ChevronRightIcon class="h-5 w-5" />
							</span>
						</a>
					))
				}
			</div>
		</section>
	</div>
</SiteLayout>
