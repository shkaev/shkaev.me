---
import SiteLayout from "./SiteLayout.astro";
import CaseStudyHero from "../components/sections/CaseStudyHero.astro";
import MediaLinkCard from "../components/sections/MediaLinkCard.astro";
import MicroLabel from "../components/typography/MicroLabel.astro";
import { resolveStaticAssetUrl } from "../lib/assetUrl";
import type { Locale } from "../i18n/config";
import { getSiteCopy } from "../i18n/copy";
import { localizePath } from "../i18n/routing";

interface MoreCaseStudyLink {
	href: string;
	title: string;
	logoSrc: string;
	logoAlt: string;
	imageSrc: string;
	imageAlt: string;
	description: string;
}

interface Props {
	title: string;
	description: string;
	pageTitle: string;
	heroSrc: string;
	heroAlt: string;
	moreCaseStudies: MoreCaseStudyLink[];
	locale?: Locale;
}

const {
	title,
	description,
	pageTitle,
	heroSrc,
	heroAlt,
	moreCaseStudies,
	locale = "en"
} = Astro.props;

const copy = getSiteCopy(locale);
const resolvedHeroSrc = resolveStaticAssetUrl(heroSrc);
const resolvedMoreCaseStudies = moreCaseStudies.map((study) => ({
	...study,
	href: localizePath(study.href, locale),
	logoSrc: resolveStaticAssetUrl(study.logoSrc),
	imageSrc: resolveStaticAssetUrl(study.imageSrc)
}));
---

<SiteLayout title={title} description={description} locale={locale}>
	<div class="case-study-content flex w-full flex-col">
		<CaseStudyHero
			title={pageTitle}
			lead={description}
			heroSrc={resolvedHeroSrc}
			heroAlt={heroAlt}
			backHref={localizePath("/design", locale)}
			backLabel={copy.design.caseStudyBackLabel}
		/>

		<slot />

		<section class="mt-20 w-full">
			<MicroLabel class="text-sm tracking-[0.24em]">{copy.design.caseStudyReadMoreLabel}</MicroLabel>
			<div class="mt-6 flex flex-col gap-4">
				{
					resolvedMoreCaseStudies.map((study) => (
						<MediaLinkCard
							href={study.href}
							title={study.title}
							logoSrc={study.logoSrc}
							imageSrc={study.imageSrc}
							imageAlt={study.imageAlt}
							description={study.description}
						/>
					))
				}
			</div>
		</section>
	</div>
</SiteLayout>
