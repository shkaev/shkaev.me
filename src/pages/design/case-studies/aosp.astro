---
import CaseStudyLayout from "../../../layouts/CaseStudyLayout.astro";
import ContentSection from "../../../components/sections/ContentSection.astro";
import CalloutBlock from "../../../components/sections/CalloutBlock.astro";
import InfoCardGrid from "../../../components/sections/InfoCardGrid.astro";
import MediaSection from "../../../components/sections/MediaSection.astro";
import MetaGrid from "../../../components/sections/MetaGrid.astro";
import MetaItem from "../../../components/sections/MetaItem.astro";
import MetricStripCard from "../../../components/sections/MetricStripCard.astro";
import SectionIntro from "../../../components/sections/SectionIntro.astro";
import SignalCard from "../../../components/sections/SignalCard.astro";
import SplitAsideSection from "../../../components/sections/SplitAsideSection.astro";
import SurfaceCard from "../../../components/sections/SurfaceCard.astro";
import MicroLabel from "../../../components/typography/MicroLabel.astro";
import CardTitle from "../../../components/typography/CardTitle.astro";
import { caseStudyCard } from "../../../case-studies/en/aosp";
import { getMoreCaseStudyCards } from "../../../case-studies/en";
import { resolveStaticAssetUrl as asset } from "../../../lib/assetUrl";

const caseStudy = caseStudyCard;
const moreCaseStudies = getMoreCaseStudyCards(caseStudy.href);
---

<CaseStudyLayout
	title={`${caseStudy.title} | Design Case Study | Dmitry Shkaev`}
	description={caseStudy.description}
	pageTitle={caseStudy.title}
	heroSrc="/images/case-studies/aosp/aosp-hero.jpg"
	heroAlt="AOSP case study hero image"
	moreCaseStudies={moreCaseStudies}
>

		<ContentSection title="Executive summary">
				<p>
					We took a sidelined browser extension with 12M+ installs and brought
					it back into the spotlight. Along with a brand new visual style,
					reformed information architecture, and a revised feature set, we
					introduced an interactive Privacy Advisor guide system.
				</p>
				<p>
					Through a meticulous design and development process, our team
					delivered a fully refreshed product to praise from users and
					leadership. Avast Online Security &amp; Privacy made a strong return
					and started to play <strong class="font-bold text-stone-950"
						>an integral role as a major digital touchpoint</strong
					> for both existing and potential customers.
				</p>
		</ContentSection>

		<ContentSection
			title="Team"
			class="border-y border-stone-200 pt-10 pb-12"
			bodyClass="mt-6 space-y-8"
		>
				<p>
					A cross-functional effort spanning product, design, research,
					engineering, QA, marketing, localization, and support. The core team
					carried the redesign from discovery through launch, with additional
					specialists supporting rollout across channels and markets.
				</p>
				<MetaGrid>
					<div class="lg:col-span-1">
						<div class="space-y-5">
							<MetaItem label="Product owner">
								<p>
									<a
										href="https://www.linkedin.com/in/petraverse/"
										target="_blank"
										rel="noreferrer"
										class="text-link text-stone-950"
									>Petra Moravcova</a>
								</p>
							</MetaItem>
							<MetaItem label="Product design lead">
								<p>
									<a
										href="https://www.linkedin.com/in/shkaev/"
										target="_blank"
										rel="noreferrer"
										class="text-link text-stone-950"
									>Dmitry Shkaev</a>
								</p>
							</MetaItem>
							<MetaItem label="Discovery">
								<p>
									<a
										href="https://www.linkedin.com/in/petr-augustin/"
										target="_blank"
										rel="noreferrer"
										class="text-link text-stone-950"
									>Petr Augustin</a>
								</p>
							</MetaItem>
							<MetaItem label="UX research">
								<p>
									<a
										href="https://www.linkedin.com/in/natalie-schinkova/"
										target="_blank"
										rel="noreferrer"
										class="text-link text-stone-950"
									>Natalie Schinkova</a>
								</p>
							</MetaItem>
							<MetaItem label="Engineering lead">
								<p>
									<a
										href="https://bit.ly/3WzT3GQ"
										target="_blank"
										rel="noreferrer"
										class="text-link text-stone-950"
									>Jiri Pojezny</a>
								</p>
							</MetaItem>
						</div>
					</div>
					<div class="lg:col-span-2">
						<div class="space-y-5">
							<MetaItem label="UX writing">
								<p>
									<a
										href="https://www.linkedin.com/in/alyyamada/"
										target="_blank"
										rel="noreferrer"
										class="text-link text-stone-950"
									>Alysa Yamada</a>
								</p>
							</MetaItem>
							<MetaItem label="Quality assurance">
								<p>
									<a
										href="https://www.linkedin.com/in/victoriausan/"
										target="_blank"
										rel="noreferrer"
										class="text-link text-stone-950"
									>Victoria Usan</a>
								</p>
							</MetaItem>
							<MetaItem label="Product marketing">
								<p>
									<a
										href="https://www.linkedin.com/in/andrew-stark-uk/"
										target="_blank"
										rel="noreferrer"
										class="text-link text-stone-950"
									>Andrew Stark</a>, <a
										href="https://www.linkedin.com/in/jbosso/"
										target="_blank"
										rel="noreferrer"
										class="text-link text-stone-950"
									>Joe Bosso</a>
								</p>
							</MetaItem>
							<MetaItem label="PR">
								<p>
									<a
										href="https://www.linkedin.com/in/marinaziegler/"
										target="_blank"
										rel="noreferrer"
										class="text-link text-stone-950"
									>Marina Ziegler</a>, <a
										href="https://www.linkedin.com/in/mike-healey-46a02320/"
										target="_blank"
										rel="noreferrer"
										class="text-link text-stone-950"
									>Mike Healey</a>, <a
										href="https://www.linkedin.com/in/stephanieaskane/"
										target="_blank"
										rel="noreferrer"
										class="text-link text-stone-950"
									>Stephanie Kane</a>
								</p>
							</MetaItem>
							<MetaItem label="Localization">
								<p>
									<a
										href="https://www.linkedin.com/in/jan-fiala-31b40182/"
										target="_blank"
										rel="noreferrer"
										class="text-link text-stone-950"
									>Jan Fiala</a>
								</p>
							</MetaItem>
						</div>
					</div>
				</MetaGrid>
		</ContentSection>

		<ContentSection title="Problem statement">
				<p>
					Amid controversial events surrounding Avast's subsidiary Jumpshot
					and its <a
						href="https://press.avast.com/en-gb/avast-to-commence-wind-down-of-subsidiary-jumpshot"
						target="_blank"
						rel="noreferrer"
						class="text-link text-stone-950"
					>shutdown in January 2020</a>, the browser extension called Avast
					Online Security was one of the immediate products that had to fall
					from grace. The practice of manipulating user data was brought to an
					abrupt end, and the company fundamentally shifted direction to
					<strong class="font-bold text-stone-950"
						>focus on protecting customer privacy</strong
					>.
				</p>
				<p>
					The extension was put into maintenance mode, its user base and store
					reviews taking a noticeable hit. After the dust settled, it had been
					lying on the shelf for over a year. In the meantime, privacy became
					a key pillar of Avast's commitment to digital freedom and one of the
					cornerstones of the upcoming rebrand.
				</p>
				<p>
					With that, it was time for such a
					<strong class="font-bold text-stone-950"
						>high-volume and impactful customer-facing product</strong
					> to get back on track, start bringing real value to users, and
					deliver on Avast's renewed privacy commitment.
				</p>
		</ContentSection>

		<section class="mt-12 w-full">
			<SectionIntro as="div" class="mt-0" title="Design goals" />
			<InfoCardGrid columnsClass="md:grid-cols-2 xl:grid-cols-3">
				<SurfaceCard>
					<MicroLabel>Framework</MicroLabel>
					<CardTitle class="mt-4 text-[1.35rem] leading-[1.08] sm:text-[1.5rem]">
						Build a new direction
					</CardTitle>
					<p class="mt-3 text-[0.98rem] leading-7 text-stone-700 sm:text-base">
						Revisit an outdated framework and redefine it through design
						thinking.
					</p>
				</SurfaceCard>
				<SurfaceCard>
					<MicroLabel>Brand</MicroLabel>
					<CardTitle class="mt-4 text-[1.35rem] leading-[1.08] sm:text-[1.5rem]">
						Launch with a new visual system
					</CardTitle>
					<p class="mt-3 text-[0.98rem] leading-7 text-stone-700 sm:text-base">
						Outfit the product with a new visual style and branding aligned
						with Avast One.
					</p>
				</SurfaceCard>
				<SurfaceCard>
					<MicroLabel>Privacy</MicroLabel>
					<CardTitle class="mt-4 text-[1.35rem] leading-[1.08] sm:text-[1.5rem]">
						Ship meaningful privacy features
					</CardTitle>
					<p class="mt-3 text-[0.98rem] leading-7 text-stone-700 sm:text-base">
						Design, build, and introduce a set of features centered on user
						privacy.
					</p>
				</SurfaceCard>
				<SurfaceCard>
					<MicroLabel>Experience</MicroLabel>
					<CardTitle class="mt-4 text-[1.35rem] leading-[1.08] sm:text-[1.5rem]">
						Design the full funnel
					</CardTitle>
					<p class="mt-3 text-[0.98rem] leading-7 text-stone-700 sm:text-base">
						Create user experiences across the full journey, from acquisition
						to retention.
					</p>
				</SurfaceCard>
				<SurfaceCard class="md:col-span-2 xl:col-span-1">
					<MicroLabel>Integration</MicroLabel>
					<CardTitle class="mt-4 text-[1.35rem] leading-[1.08] sm:text-[1.5rem]">
						Connect it to the product ecosystem
					</CardTitle>
					<p class="mt-3 text-[0.98rem] leading-7 text-stone-700 sm:text-base">
						Build integrations with the existing lineup and pave the way for
						future connection to the flagship product.
					</p>
				</SurfaceCard>
				<SurfaceCard>
					<MicroLabel>Retention</MicroLabel>
					<CardTitle class="mt-4 text-[1.35rem] leading-[1.08] sm:text-[1.5rem]">
						Increase everyday relevance
					</CardTitle>
					<p class="mt-3 text-[0.98rem] leading-7 text-stone-700 sm:text-base">
						Make the extension useful enough to become part of users' regular
						browsing habits.
					</p>
				</SurfaceCard>
			</InfoCardGrid>
		</section>

		<section class="mt-12 w-full">
			<SectionIntro as="div" class="mt-0" title="Design process">
				<p>
					At the core of our design process we employed the classic
					<strong class="font-bold text-stone-950"
						>double diamond design model</strong
					>. The initial kick-off and discovery phase were covered by my
					teammate Petr, who thoroughly explored multiple directions and
					produced an extensive body of research.
				</p>
			</SectionIntro>
			<CalloutBlock
				label="My role"
				title="Turning discovery into a finished product direction"
				body="I picked up the torch when it came to narrowing down the scope, defining the problem, expanding the work from concepts to high fidelity, testing, and delivering the final results."
				class="mt-8"
			>
				<span slot="label-prefix" class="-translate-y-px text-amber-500">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 20 20"
							fill="currentColor"
							class="h-4 w-4"
							aria-hidden="true"
						>
							<path
								fill-rule="evenodd"
								d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401Z"
								clip-rule="evenodd"
							></path>
						</svg>
				</span>
			</CalloutBlock>
			<div class="mt-8 overflow-hidden rounded-[12px] bg-white/80 shadow-[0_1px_0_rgba(28,25,23,0.04)]">
				<img
				src={asset("/images/case-studies/aosp/aosp-process.png")}
					alt="AOSP design process diagram"
					class="h-auto w-full"
					loading="lazy"
				/>
			</div>
		</section>

		<ContentSection title="Issues of the old product">
				<p>
					When defining the new information architecture, our initial approach
					was to retain the single-screen framework and use widget-style cards.
					I quickly discovered that it would not be ideal.
				</p>
				<div class="mt-8 grid gap-4 md:grid-cols-2">
					<SignalCard variant="negative">
						<p class="[text-wrap:pretty] text-lg leading-7 text-rose-900 dark:text-rose-200">
							It lacked a focal point on the main screen and did not make the
							best use of UI space.
						</p>
					</SignalCard>
					<SignalCard variant="negative">
						<p class="[text-wrap:pretty] text-lg leading-7 text-rose-900 dark:text-rose-200">
							Multiple jobs-to-be-done would compete for users' attention.
						</p>
					</SignalCard>
					<SignalCard variant="negative">
						<p class="[text-wrap:pretty] text-lg leading-7 text-rose-900 dark:text-rose-200">
							Tons of controls would further dilute the experience.
						</p>
					</SignalCard>
					<SignalCard variant="negative">
						<p class="[text-wrap:pretty] text-lg leading-7 text-rose-900 dark:text-rose-200">
							There were more features packed in than before, and we still
							needed room to scale.
						</p>
					</SignalCard>
				</div>
				<div class="mt-8 overflow-hidden rounded-[12px] bg-white/80 shadow-[0_1px_0_rgba(28,25,23,0.04)]">
					<img
						src={asset("/images/case-studies/aosp/aosp-architecture.png")}
						alt="AOSP information architecture redesign"
						class="h-auto w-full"
						loading="lazy"
					/>
				</div>
		</ContentSection>

		<section class="mt-12 w-full">
			<SectionIntro
				as="div"
				class="mt-0"
				title="New information architecture"
				bodyVariant="lead"
			>
				<p>
					Each UI element and user journey was scrutinized and iterated on.
					Many variables affected the decision-making process. For the purposes
					of this case study, I focused on the refined post-feedback screens
					and the decisions behind them.
				</p>
			</SectionIntro>
			<div class="mt-8 grid gap-4 md:grid-cols-2">
				<SignalCard>
					<p class="[text-wrap:pretty] text-lg leading-7 text-emerald-900 dark:text-emerald-200">
						The focal point became immediately clear, and the layout made much
						better use of UI space.
					</p>
				</SignalCard>
				<SignalCard>
					<p class="[text-wrap:pretty] text-lg leading-7 text-emerald-900 dark:text-emerald-200">
						Jobs-to-be-done were separated into their own sections and no
						longer interfered with each other.
					</p>
				</SignalCard>
				<SignalCard>
					<p class="[text-wrap:pretty] text-lg leading-7 text-emerald-900 dark:text-emerald-200">
						Each screen had a single primary action and, at most, a secondary
						one.
					</p>
				</SignalCard>
				<SignalCard>
					<p class="[text-wrap:pretty] text-lg leading-7 text-emerald-900 dark:text-emerald-200">
						The new sidebar structure created breathing room for richer
						feature detail and future additions.
					</p>
				</SignalCard>
			</div>
			<div class="mt-8 overflow-hidden rounded-[12px] bg-white/80 shadow-[0_1px_0_rgba(28,25,23,0.04)]">
				<img
					src={asset("/images/case-studies/aosp/aosp-high-fidelity.png")}
					alt="AOSP high-fidelity interface designs"
					class="h-auto w-full"
					loading="lazy"
				/>
			</div>
		</section>

		<ContentSection title="Prototype">
				<p>
					After multiple rounds of presenting new concepts to stakeholders
					and gathering feedback from designers and engineers, I got the
					green light to produce high-fidelity assets and build a prototype
					in Figma. That prototype helped us collect further feedback both
					internally and externally, and it became the basis for qualitative
					user testing with three target groups:
				</p>
				<ul class="list-inside list-disc space-y-4 text-stone-700 marker:text-stone-950 dark:marker:text-stone-200">
					<li>People who were already using this browser extension.</li>
					<li>People who were using our products and were familiar with the brand.</li>
					<li>General participants with no prior familiarity with our products.</li>
				</ul>
		</ContentSection>

		<MediaSection
			src={asset("/images/case-studies/aosp/aosp-research.png")}
			alt="AOSP prototype and research screens"
		/>

		<ContentSection title="User experience research outcome">
				<p>
					Users responded well to the redesign, especially the new light
					visual style, and they moved through the product with ease.
				</p>
				<p>
					Some features were conceptually unfamiliar, which meant a few
					people did not immediately understand what they were looking at. We
					addressed that by simplifying verbose copy and, in some cases,
					replacing full paragraphs with a single line and a link to the
					relevant help section. We documented every moment of hesitation or
					friction around navigation and actions, so I could <strong
						class="font-bold text-stone-950"
					>smooth out those rough edges</strong> in the next iteration.
				</p>
		</ContentSection>

		<MediaSection
			src={asset("/images/case-studies/aosp/aosp-handoff.jpg")}
			alt="AOSP design handoff and implementation"
		/>

		<section class="mt-12 w-full">
			<SectionIntro as="div" class="mt-0" title="Handoff" />
			<SplitAsideSection>
				<div slot="main" class="space-y-4 text-base leading-8 text-stone-700 sm:text-lg">
					<p>
						After a couple more iteration cycles, we were satisfied with the
						new designs, so it was time to hand them off to development. As a
						designer, I always try to <strong class="font-bold text-stone-950"
							>support the devs' workflow</strong
						> by including them in the process as early as possible and
						providing meaningful, self-contained deliverables as the project
						moves forward.
					</p>
					<p>
						This gave engineers a much easier time with sprint planning and
						let them work on the foundation while hi-fi designs were still
						being prepared and finalized.
					</p>
					<p>
						During development I had close back-and-forth with engineers to
						make sure everything matched the established vision. Once visuals
						started coming in, we held regular sessions to iron out rough
						spots. Despite the team working remotely, I happened to be in the
						same city as our main frontend developer, so we made the most of
						it and worked together in person.
					</p>
				</div>
				<div slot="aside">
					<CardTitle as="h3" class="text-[1.2rem] sm:text-[1.3rem]">
						Some examples from this project
					</CardTitle>
					<div class="mt-4 space-y-4 text-stone-700">
						<div class="flex items-start gap-3">
							<span class="mt-1 shrink-0 text-stone-400 dark:text-stone-500">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									viewBox="0 0 20 20"
									fill="currentColor"
									class="h-4 w-4"
									aria-hidden="true"
								>
									<path
										fill-rule="evenodd"
										d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401Z"
										clip-rule="evenodd"
									></path>
								</svg>
							</span>
							<p>
								Early prioritization and alignment on which features stayed or
								were cut. This let developers refactor old code and prepare the
								backend foundation for new features.
							</p>
						</div>
						<div class="flex items-start gap-3">
							<span class="mt-1 shrink-0 text-stone-400 dark:text-stone-500">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									viewBox="0 0 20 20"
									fill="currentColor"
									class="h-4 w-4"
									aria-hidden="true"
								>
									<path
										fill-rule="evenodd"
										d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401Z"
										clip-rule="evenodd"
									></path>
								</svg>
							</span>
							<p>
								Parallel work on the general structure, giving the team a clear
								view of what frontend development would require.
							</p>
						</div>
						<div class="flex items-start gap-3">
							<span class="mt-1 shrink-0 text-stone-400 dark:text-stone-500">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									viewBox="0 0 20 20"
									fill="currentColor"
									class="h-4 w-4"
									aria-hidden="true"
								>
									<path
										fill-rule="evenodd"
										d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401Z"
										clip-rule="evenodd"
									></path>
								</svg>
							</span>
							<p>
								Early delivery of collateral such as Privacy Advisor messages,
								interactive guides, updated web pages, and scenario-specific
								messaging before frontend work became fully occupied with the
								main UI.
							</p>
						</div>
					</div>
				</div>
			</SplitAsideSection>
		</section>

		<ContentSection title="Localization to 20+ languages">
				<p>
					AOSP was available globally and had to be localized across
					European, Asian, and Middle Eastern markets with every release or
					update.
				</p>
				<p>
					This introduced another level of complexity. One example was
					producing promotional materials for various online stores. Another
					was text length variability across languages, sometimes dramatic
					enough to break the UI. Credit to our QA team for catching every
					instance where that became a problem, so we could fix it in a timely
					manner.
				</p>
		</ContentSection>

		<MediaSection
			src={asset("/images/case-studies/aosp/aosp-localization.png")}
			alt="AOSP localization and store assets"
		/>

		<section class="mt-12 w-full">
			<SectionIntro as="div" class="mt-0" title="How we measured success">
				<p>
					Avast has a wide array of analytics tools to establish and track
					almost any metric, all stripped of personal data. Some of the things
					we looked at included:
				</p>
				<div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
					<MetricStripCard title="Product adoption">
						Onboarding success, core flow completion rates and feature
						opt-ins. Engagement over the first month.
					</MetricStripCard>
					<MetricStripCard title="Usage &amp; interaction">
						More specific data on how people used each feature, helping us
						understand what brought the most value.
					</MetricStripCard>
					<MetricStripCard title="Privacy Advisor">
						Guide completion, depth, popularity across guides, platform
						rankings, and other engagement signals.
					</MetricStripCard>
					<MetricStripCard title="Promotional messaging">
						Engagement with in-product promotions and cross-sell
						opportunities, later extended into a subscription-based model.
					</MetricStripCard>
					<MetricStripCard title="User signals">
						NPS, surveys, built-in quick feedback forms, store review
						dynamics, and additional rounds of user testing.
					</MetricStripCard>
					<MetricStripCard
						title="Churn and retention"
						class="md:col-span-2 xl:col-span-1"
					>
						Installs versus uninstalls after the redesign, including the
						initial dormant-user spike and the later recovery once campaigns
						resumed.
					</MetricStripCard>
				</div>
			</SectionIntro>
		</section>

