---
import CaseStudyLayout from "../../../../layouts/CaseStudyLayout.astro";
import CalloutColumn from "../../../../components/sections/CalloutColumn.astro";
import ContentSection from "../../../../components/sections/ContentSection.astro";
import CalloutBlock from "../../../../components/sections/CalloutBlock.astro";
import InfoCardGrid from "../../../../components/sections/InfoCardGrid.astro";
import MediaSection from "../../../../components/sections/MediaSection.astro";
import MetaGrid from "../../../../components/sections/MetaGrid.astro";
import MetaItem from "../../../../components/sections/MetaItem.astro";
import SectionIntro from "../../../../components/sections/SectionIntro.astro";
import SplitAsideSection from "../../../../components/sections/SplitAsideSection.astro";
import SurfaceCard from "../../../../components/sections/SurfaceCard.astro";
import MicroLabel from "../../../../components/typography/MicroLabel.astro";
import CardTitle from "../../../../components/typography/CardTitle.astro";
import SectionBody from "../../../../components/typography/SectionBody.astro";
import { resolveStaticAssetUrl as asset } from "../../../../lib/assetUrl";

const moreCaseStudies = [
	{
		href: "/design/case-studies/aosp",
		title: "Avast Online Security & Privacy",
		logoSrc: "/favicons/avast.ico",
		logoAlt: "Avast",
		imageSrc: "/images/case-studies/aosp/aosp-hero.jpg",
		imageAlt: "Превью кейса Avast Online Security & Privacy",
		description:
			"Крупный редизайн флагманского браузерного расширения с аудиторией более 10 миллионов пользователей."
	},
	{
		href: "/design/case-studies/trackoff",
		title: "TrackOFF",
		logoSrc: "/favicons/trackoff.png",
		logoAlt: "TrackOFF",
		imageSrc: "/images/case-studies/trackoff/trackoff-hero.jpg",
		imageAlt: "Превью кейса TrackOFF",
		description:
			"Короткая история о том, как продукт строился с нуля и дошёл до поглощения."
	}
];
---

<CaseStudyLayout
	title="Cookie Manager | Дизайн-кейс | Дмитрий Шкаев"
	description="Проектирование, создание и интеграция новой функции в Avast Online Security & Privacy."
	pageTitle="Cookie Manager"
	heroSrc="/images/case-studies/cookie-manager/cookie-manager-hero.jpg"
	heroAlt="Обложка кейса Cookie Manager"
	moreCaseStudies={moreCaseStudies}
	locale="ru"
>

		<ContentSection title="Краткое резюме" bodyClass="mt-6">
			<p>
				Развивая успешный редизайн Avast Online Security &amp; Privacy, наша
				команда спроектировала новую функцию для флагманского браузерного
				расширения компании. Это позволило расширить первоначальное
				предложение и мягче выстроить путь к платной модели, а также к
				интеграции с <a
					href="https://www.avast.com/avast-one"
					target="_blank"
					rel="noreferrer"
						class="text-link text-stone-950"
					>Avast One</a>.
			</p>
		</ContentSection>

		<ContentSection
			title="Команда"
			class="border-y border-stone-200 pt-10 pb-12"
			bodyClass="mt-6 space-y-8"
		>
				<p>
					Компактная кросс-функциональная команда провела Cookie Manager от
					формулировки продукта через дизайн, исследование, реализацию и
					запуск.
				</p>
				<MetaGrid>
					<div class="lg:col-span-1">
						<div class="space-y-5">
							<MetaItem label="Владелец продукта">
								<p>
									<a
										href="https://www.linkedin.com/in/ron-ward-30432894/"
										target="_blank"
										rel="noreferrer"
										class="text-link text-stone-950"
									>Ron Ward</a>
								</p>
							</MetaItem>
							<MetaItem label="Продуктовый дизайнер">
								<p>
									<a
										href="https://www.linkedin.com/in/shkaev/"
										target="_blank"
										rel="noreferrer"
										class="text-link text-stone-950"
									>Dmitry Shkaev</a>
								</p>
							</MetaItem>
							<MetaItem label="Разработка">
								<p>
									<a
										href="https://bit.ly/3WzT3GQ"
										target="_blank"
										rel="noreferrer"
										class="text-link text-stone-950"
									>Jiri Pojezny</a>, <a
										href="https://www.linkedin.com/in/gilyov/"
										target="_blank"
										rel="noreferrer"
										class="text-link text-stone-950"
									>Anton Gilyov</a>
								</p>
							</MetaItem>
						</div>
					</div>
					<div class="lg:col-span-2">
						<div class="space-y-5">
							<MetaItem label="UX-исследование">
								<p>
									<a
										href="https://www.linkedin.com/in/natalie-schinkova/"
										target="_blank"
										rel="noreferrer"
										class="text-link text-stone-950"
									>Natalie Schinkova</a>, <a
										href="https://www.linkedin.com/in/veronikakonecna/"
										target="_blank"
										rel="noreferrer"
										class="text-link text-stone-950"
									>Veronika Konecna</a>
								</p>
							</MetaItem>
							<MetaItem label="UX-райтинг">
								<p>
									<a
										href="https://www.linkedin.com/in/alyyamada/"
										target="_blank"
										rel="noreferrer"
										class="text-link text-stone-950"
									>Alysa Yamada</a>
								</p>
							</MetaItem>
						</div>
					</div>
				</MetaGrid>
		</ContentSection>

		<section class="mt-12 w-full">
			<SectionIntro as="div" class="mt-0" title="Постановка задачи" />
			<div class="mt-6 grid gap-8 lg:grid-cols-3">
				<CalloutColumn title="Приобретённый продукт" bodyClass="space-y-4">
					<p>
						В 2021 году Avast <a
							href="https://www.i-dont-care-about-cookies.eu/whats-new/acquisition/"
							target="_blank"
							rel="noreferrer"
							class="text-link text-stone-950"
						>приобрела</a> популярное браузерное расширение I Don't Care
						About Cookies, созданное хорватским разработчиком <a
							href="https://www.linkedin.com/in/dkladnik/"
							target="_blank"
							rel="noreferrer"
							class="text-link text-stone-950"
						>Daniel Kladnik</a>. У продукта уже был очевидный спрос: он
						убирал запросы согласия на cookies и позволял людям пользоваться
						браузером с меньшим количеством отвлекающих элементов, что
						особенно важно на рынках с жёстким GDPR.
					</p>
				</CalloutColumn>
				<CalloutColumn title="Почему его поставили на паузу" bodyClass="space-y-4">
					<p>
						Идея была в том, чтобы встроить эту возможность в один из
						продуктов Avast для защиты приватности, сначала в Avast
						AntiTrack. Но как
						платный инструмент он был не самой подходящей средой, чтобы
						раскрыть широкий пользовательский эффект от приобретения. На
						фоне более крупных внутренних изменений в Avast купленное
						расширение временно убрали в запас.
					</p>
				</CalloutColumn>
				<CalloutColumn title="Почему подошёл AOSP" bodyClass="space-y-4">
					<p>
						Ситуация изменилась, когда к концу 2021 года возродили <a
							href="/ru/design/case-studies/aosp"
							class="text-link text-stone-950"
						>Avast Online Security &amp; Privacy</a>. AOSP быстро стал одним
						из ключевых продуктов компании и оказался первым местом, где
						это приобретение могло усилить основное ценностное предложение,
						а не выглядеть чужеродным дополнением.
					</p>
				</CalloutColumn>
			</div>
			<CalloutBlock
				label="Моя роль"
				title="Превратить приобретение в продуктовую функцию"
				body="Как дизайнер Avast Online Security & Privacy, я возглавил работу по тому, чтобы встроить это приобретение в продукт как цельную и понятную функцию."
				class="mt-8"
			>
				<span slot="label-prefix" class="-translate-y-px text-amber-500">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 20 20"
							fill="currentColor"
							class="h-4 w-4"
							aria-hidden="true"
						>
							<path
								fill-rule="evenodd"
								d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401Z"
								clip-rule="evenodd"
							></path>
						</svg>
				</span>
			</CalloutBlock>
		</section>

		<MediaSection
			src={asset("/images/case-studies/cookie-manager/cookie-manager-wireframes.jpg")}
			alt="Вайрфреймы Cookie Manager"
		/>

		<section class="mt-12 w-full">
			<SectionIntro as="div" class="mt-0" title="Цели дизайна" />
			<InfoCardGrid>
				<SurfaceCard>
					<MicroLabel>Поток</MicroLabel>
					<CardTitle class="mt-4 text-[1.35rem] leading-[1.08] sm:text-[1.5rem]">
						Сделать просмотр сайтов непрерывным
					</CardTitle>
					<p class="mt-3 text-[0.98rem] leading-7 text-stone-700 sm:text-base">
						Помочь людям убирать cookie-баннеры с пути вместо того, чтобы
						они постоянно ломали поток.
					</p>
				</SurfaceCard>
				<SurfaceCard>
					<MicroLabel>Сложность</MicroLabel>
					<CardTitle class="mt-4 text-[1.35rem] leading-[1.08] sm:text-[1.5rem]">
						Выйти за пределы простых сценариев
					</CardTitle>
					<p class="mt-3 text-[0.98rem] leading-7 text-stone-700 sm:text-base">
						Разобрать многовариантные сценарии согласия, которые исходное
						расширение не закрывало до конца.
					</p>
				</SurfaceCard>
				<SurfaceCard>
					<MicroLabel>Интеграция</MicroLabel>
					<CardTitle class="mt-4 text-[1.35rem] leading-[1.08] sm:text-[1.5rem]">
						Сделать это частью продукта
					</CardTitle>
					<p class="mt-3 text-[0.98rem] leading-7 text-stone-700 sm:text-base">
						Встроить новую функцию в недавно обновлённый каркас так, чтобы
						она ощущалась родной и в UX, и в визуальном языке.
					</p>
				</SurfaceCard>
			</InfoCardGrid>
		</section>

		<section class="mt-12 w-full">
			<SectionIntro as="div" class="mt-0" title="Процесс дизайна" />
			<SplitAsideSection gridClass="lg:grid lg:grid-cols-[minmax(0,3fr)_minmax(0,1fr)] lg:items-stretch lg:gap-10">
				<div slot="main">
					<SectionBody class="mt-0">
						<p>
							К моменту старта дизайна бизнес-обоснование уже было готово,
							так что классический исследовательский этап не требовался. Первой
							задачей было понять, где эта новая возможность должна жить
							внутри продукта. У исходного расширения почти не было
							интерфейса, поэтому фактически мы начали с нуля, при этом
							переиспользуя часть серверной логики.
						</p>
					</SectionBody>
					<CalloutBlock
						label="Следующие шаги"
						title="От первых набросков к пользовательскому тестированию"
						body="Я подготовил вайрфреймы, закрывающие все ключевые идеи и требования. Затем мы провели несколько раундов внутреннего фидбека, а после этого я сделал детально проработанные макеты для первого внешнего пользовательского теста."
						class="mt-8"
					>
						<span slot="label-prefix" class="-translate-y-px text-amber-500">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									viewBox="0 0 20 20"
									fill="currentColor"
									class="h-4 w-4"
									aria-hidden="true"
								>
									<path
										fill-rule="evenodd"
										d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401Z"
										clip-rule="evenodd"
									></path>
								</svg>
						</span>
					</CalloutBlock>
				</div>
				<div slot="aside">
					<CalloutColumn
						title="Задача"
						titleAs="h3"
						titleClass="text-[1.2rem] sm:text-[1.3rem]"
						bodyClass="space-y-4 text-[0.98rem] leading-7 sm:text-base"
					>
						<p>
							Найти баланс между ценностью для пользователя, удобством,
							заметностью внутри продукта и бизнес-эффектом, не оттягивая
							слишком много внимания от основных функций.
						</p>
						<p>
							Ранние концепты шли от простого чекбокса до отдельной зоны в
							интерфейсе. В итоге победило более насыщенное решение с
							переключателем on/off, индикаторами ценности, настройкой и
							whitelisting.
						</p>
					</CalloutColumn>
				</div>
			</SplitAsideSection>
		</section>

		<ContentSection title="Прототип">
				<p>
					После того как команда посмотрела детально проработанные экраны и владелец
					проекта дал добро, я собрал прототип в Figma, повторяющий весь
					путь от установки расширения до обнаружения и использования
					Cookie Manager.
				</p>
				<p>
					Перед интервью мы собрали вопросы от всех стейкхолдеров и
					ключевых членов команды. Интервью проводили мои коллеги Natalie и
					Veronika. Я подключился к одному из первых звонков, чтобы
					проверить, идём ли мы в правильном направлении и получаем ли
					полезную информацию. Они также отлично собрали подробное резюме
					по результатам. Позже я всё равно отдельно пересмотрел все
					записи, чтобы отметить конкретные наблюдения, которые искал.
				</p>
		</ContentSection>

		<MediaSection
			src={asset("/images/case-studies/cookie-manager/cookie-manager-prototype.png")}
			alt="Экраны прототипа Cookie Manager"
		/>

		<ContentSection title="Результат UX-исследования">
				<p>
					Результаты оказались сильными и в некоторых местах даже
					неожиданными. Это был один из самых полезных раундов
					качественного UX-исследования за долгое время: люди поделились
					большим количеством важных инсайтов. Как это часто бывает, часть
					наших прежних предположений не подтвердилась, а часть сработала
					очень хорошо.
				</p>
				<p>
					Например, сначала мы взяли систему всплывающих подсказок из Avast One, где
					человек наводил курсор на значок вопроса и читал короткую
					подсказку. Этот паттерн существует ещё со времён первых
					графических ОС, так что он казался очевидным для пользователя. В
					реальности его нашли только двое из десяти, и лишь один из них
					вообще стал читать текст. Даже этот человек с трудом понимал, что
					именно мы хотели донести.
				</p>
				<p>
					В целом функцию приняли хорошо, а проблемы с удобством были от
					умеренных до незначительных. Мы показали команде сводку по
					результатам, чтобы вместе обсудить и расставить приоритеты.
				</p>
		</ContentSection>

		<MediaSection
			src={asset("/images/case-studies/cookie-manager/cookie-manager-research.png")}
			alt="Результаты пользовательского исследования Cookie Manager"
		/>

		<section class="mt-12 w-full">
			<div class="space-y-4 text-base leading-8 text-stone-700 sm:text-lg">
				<p>
					Дальше я занялся тем, чтобы структурировать, проверить и внедрить
					согласованные правки.
				</p>
				<p>
					<strong class="font-bold text-stone-950"
						>В результате этого исследования мы по-новому взглянули на то,
						как показывать сложные cookie-окна и набор доступных
						пользователю опций.</strong
					> В идеале за этим должен был последовать второй раунд
					качественного исследования, но из-за сжатых сроков мы решили
					идти в релиз, собрать количественные данные и вернуться к функции
					во второй фазе.
				</p>
			</div>
		</section>

		<MediaSection
			src={asset("/images/case-studies/cookie-manager/cookie-manager-handoff.png")}
			alt="Финальный дизайн Cookie Manager и передача в разработку"
		/>

		<section class="mt-12 w-full">
			<div class="grid gap-4 lg:grid-cols-3">
				<SurfaceCard as="article">
					<CardTitle as="h2" class="text-[1.35rem] leading-tight sm:text-[1.5rem]">
						Передача в разработку
					</CardTitle>
					<p class="mt-3 text-[0.98rem] leading-7 text-stone-700 sm:text-base">
						Над проектом работала выделенная команда инженеров, так что мы
						начали сотрудничать сразу же после старта. Работая вместе, мы
						итеративно и по графику доводили функцию до релиза, быстро
						разбирая возникавшие проблемы. Мне особенно понравилось,
						насколько точно фронтенд-реализация совпала с дизайном.
					</p>
				</SurfaceCard>

				<SurfaceCard as="article">
					<CardTitle as="h2" class="text-[1.35rem] leading-tight sm:text-[1.5rem]">
						Как мы измеряли успех
					</CardTitle>
					<p class="mt-3 text-[0.98rem] leading-7 text-stone-700 sm:text-base">
						OKR были чётко определены: выпустить в срок, улучшить
						пользовательское принятие после релиза, измерять влияние на продажи от кросс-промо
						кампаний, поднять NPS на заданную величину и несколько других
						метрик.
					</p>
				</SurfaceCard>

				<SurfaceCard as="article">
					<CardTitle as="h2" class="text-[1.35rem] leading-tight sm:text-[1.5rem]">
						Результаты
					</CardTitle>
					<p class="mt-3 text-[0.98rem] leading-7 text-stone-700 sm:text-base">
						Мы успешно выпустили Cookie Manager и запустили его вместе с
						маркетинговой кампанией. Это стало важной вехой в развитии
						AOSP. В последующие месяцы показатели использования и
						вовлечённости у Cookie Manager превзошли наши ожидания.
					</p>
				</SurfaceCard>
			</div>
		</section>

		<ContentSection title="Личный вывод">
				<p>
					Это был идеальный пример полноценной, стандартной дизайн-работы в
					корпоративной среде, если не считать исследовательского этапа. С виду
					такие проекты могут казаться рутиной, но каждый из них по-своему
					уникален и приносит свои задачи. В этом случае мне особенно
					понравилось, как пользовательское исследование изменило наши
					дизайнерские решения и заметно повлияло на сложность информации,
					которую видели пользователи.
				</p>
				<p>
					В рамках одного проекта у меня был шанс придумать новую
					информационную архитектуру, сделать сырые концепты, собрать
					прототипы, проверить идеи через фидбек-сессии и исследования,
					собрать детально проработанный UI, передать всё разработчикам и вместе с
					ними проследить за реализацией. Тут было буквально всё.
				</p>
		</ContentSection>

</CaseStudyLayout>
