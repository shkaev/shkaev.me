---
import { getCollection } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";
import PageHero from "../../components/sections/PageHero.astro";
import { getSiteCopy } from "../../i18n/copy";
import { localizePath } from "../../i18n/routing";
import { resolvePhotoAssetUrl } from "../../lib/photoAsset";
import { formatPhotoTimeframe } from "../../lib/photoTimeframe";
import { resolveCountryFlag, resolveCountryLabel } from "../../lib/countryFlags";
import {
	resolveLocalizedPhotoSeriesSummary,
	resolveLocalizedPhotoSeriesTitle
} from "../../lib/photoSeriesLocalization";

const locale = "ru" as const;
const copy = getSiteCopy(locale);

const parseSeriesYear = (timeframe: string) => {
	const match = timeframe.match(/\b(19|20)\d{2}\b/u);

	return match ? Number.parseInt(match[0], 10) : null;
};

const series = (await getCollection("photo-series"))
	.map((entry) => ({
		...entry,
		data: {
			...entry.data,
			year: parseSeriesYear(entry.data.timeframe)
		}
	}))
	.sort((a, b) => b.data.sortOrder - a.data.sortOrder);

const sortOptions = copy.photography.sortOptions;

const countryOptions = Array.from(
	new Set(series.map((entry) => entry.data.cardLocation))
).sort((left, right) =>
	resolveCountryLabel(left, locale).localeCompare(resolveCountryLabel(right, locale))
);

const yearOptions = Array.from(
	new Set(
		series
			.map((entry) => entry.data.year)
			.filter((year): year is number => year !== null)
	)
).sort((left, right) => right - left);

const formatYearLabel = (year: number | string) =>
	String(year) === "2003" ? copy.photography.legacyYearLabel : String(year);
const buildSearchTerms = (entry: (typeof series)[number]) => {
		const terms = [
			resolveLocalizedPhotoSeriesTitle(entry.data.title, locale),
			entry.data.summary,
			resolveLocalizedPhotoSeriesSummary(entry.data.summary, locale),
			entry.data.location,
		entry.data.timeframe,
		formatPhotoTimeframe(entry.data.timeframe, locale),
		entry.data.cardLocation,
		resolveCountryLabel(entry.data.cardLocation, locale),
		entry.data.year ? String(entry.data.year) : ""
	];

	if (entry.data.slug === "2003-2007-old-film-collection") {
		terms.push("legacy", "2003", "2004", "2005", "2006", "2007");
	}

	return terms.join(" ").toLowerCase();
};

const renderedSeries = series.map((entry, index, entries) => {
	const currentYear = entry.data.year ? String(entry.data.year) : "";
	const previousYear =
		index > 0
			? entries[index - 1]?.data.year
				? String(entries[index - 1].data.year)
				: ""
			: "";

	return {
		entry,
		currentYear,
		shouldRenderDivider: currentYear !== previousYear,
		searchIndex: buildSearchTerms(entry)
	};
});
---

<SiteLayout
	title={copy.photography.metaTitle}
	description={copy.photography.metaDescription}
	locale={locale}
>
	<section class="w-full" data-photography-root>
		<PageHero
			eyebrow={copy.photography.eyebrow}
			title={copy.photography.title}
			lead={copy.photography.lead}
			leadClass="max-w-4xl"
		/>

		<div class="mt-7">
			<div
				class="grid gap-2 lg:grid-cols-[minmax(0,1.8fr)_repeat(3,minmax(0,0.8fr))]"
				data-photography-controls
			>
					<label class="relative flex min-w-0 flex-col">
								<input
									type="search"
									name="q"
									placeholder={copy.photography.searchPlaceholder}
									autocomplete="off"
									aria-label={copy.photography.searchAriaLabel}
								data-hover-card
								data-photography-search
								class="h-11 rounded-full border border-stone-200/80 bg-white px-4 pr-11 text-[0.96rem] text-stone-900 outline-none shadow-[inset_0_1px_2px_rgba(120,113,108,0.08),inset_0_1px_0_rgba(255,255,255,0.6)] transition placeholder:text-stone-500 hover:border-stone-300 focus:border-stone-300 focus:bg-white focus:shadow-[inset_0_1px_2px_rgba(120,113,108,0.1),0_0_0_1px_rgba(255,255,255,0.75)] dark:bg-stone-900 dark:text-stone-100 dark:placeholder:text-stone-400 dark:shadow-[inset_0_1px_2px_rgba(0,0,0,0.38),inset_0_1px_0_rgba(255,255,255,0.05)] dark:focus:border-[rgb(120_113_108)] dark:focus:bg-stone-900 dark:focus:shadow-[inset_0_1px_2px_rgba(0,0,0,0.42),0_0_0_1px_rgba(87,83,78,0.5)]"
							/>
								<button
									type="button"
									aria-label={copy.photography.clearSearchAriaLabel}
								data-search-clear
									class="group absolute inset-y-0 right-1.5 my-auto hidden size-8 cursor-pointer items-center justify-center rounded-full text-stone-400 transition hover:bg-stone-100 hover:text-stone-700 dark:text-stone-500 dark:hover:bg-stone-800"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									viewBox="0 0 20 20"
									fill="currentColor"
									class="size-5 transition group-hover:text-stone-700 dark:group-hover:text-white"
									aria-hidden="true"
								>
								<path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
							</svg>
						</button>
				</label>

					<label class="group relative flex min-w-0 flex-col">
							<select
									name="country"
									aria-label={copy.photography.countryAriaLabel}
									data-hover-card
									data-photography-country
									class="filter-select-pill"
							>
							<option value="all">{copy.photography.allCountriesLabel}</option>
								{
									countryOptions.map((country) => (
										<option value={country}>{resolveCountryLabel(country, locale)}</option>
									))
								}
						</select>
							<span class="filter-select-pill-icon">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								viewBox="0 0 16 16"
								fill="currentColor"
								class="size-4"
								aria-hidden="true"
							>
								<path
									fill-rule="evenodd"
									d="M5.22 10.22a.75.75 0 0 1 1.06 0L8 11.94l1.72-1.72a.75.75 0 1 1 1.06 1.06l-2.25 2.25a.75.75 0 0 1-1.06 0l-2.25-2.25a.75.75 0 0 1 0-1.06ZM10.78 5.78a.75.75 0 0 1-1.06 0L8 4.06 6.28 5.78a.75.75 0 0 1-1.06-1.06l2.25-2.25a.75.75 0 0 1 1.06 0l2.25 2.25a.75.75 0 0 1 0 1.06Z"
									clip-rule="evenodd"
								/>
							</svg>
						</span>
				</label>

					<label class="group relative flex min-w-0 flex-col">
							<select
									name="year"
									aria-label={copy.photography.yearAriaLabel}
								data-hover-card
								data-photography-year
								class="filter-select-pill"
						>
								<option value="all">{copy.photography.allYearsLabel}</option>
							{
								yearOptions.map((year) => (
									<option value={String(year)}>{formatYearLabel(year)}</option>
								))
							}
						</select>
							<span class="filter-select-pill-icon">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								viewBox="0 0 16 16"
								fill="currentColor"
								class="size-4"
								aria-hidden="true"
							>
								<path
									fill-rule="evenodd"
									d="M5.22 10.22a.75.75 0 0 1 1.06 0L8 11.94l1.72-1.72a.75.75 0 1 1 1.06 1.06l-2.25 2.25a.75.75 0 0 1-1.06 0l-2.25-2.25a.75.75 0 0 1 0-1.06ZM10.78 5.78a.75.75 0 0 1-1.06 0L8 4.06 6.28 5.78a.75.75 0 0 1-1.06-1.06l2.25-2.25a.75.75 0 0 1 1.06 0l2.25 2.25a.75.75 0 0 1 0 1.06Z"
									clip-rule="evenodd"
								/>
							</svg>
						</span>
				</label>

					<label class="group relative flex min-w-0 flex-col">
							<select
									name="sort"
									aria-label={copy.photography.sortAriaLabel}
								data-hover-card
								data-photography-sort
								class="filter-select-pill"
						>
							{
								sortOptions.map((option) => (
									<option value={option.value}>{option.label}</option>
								))
							}
						</select>
							<span class="filter-select-pill-icon">
							<svg
								xmlns="http://www.w3.org/2000/svg"
								viewBox="0 0 16 16"
								fill="currentColor"
								class="size-4"
								aria-hidden="true"
							>
								<path
									fill-rule="evenodd"
									d="M5.22 10.22a.75.75 0 0 1 1.06 0L8 11.94l1.72-1.72a.75.75 0 1 1 1.06 1.06l-2.25 2.25a.75.75 0 0 1-1.06 0l-2.25-2.25a.75.75 0 0 1 0-1.06ZM10.78 5.78a.75.75 0 0 1-1.06 0L8 4.06 6.28 5.78a.75.75 0 0 1-1.06-1.06l2.25-2.25a.75.75 0 0 1 1.06 0l2.25 2.25a.75.75 0 0 1 0 1.06Z"
									clip-rule="evenodd"
								/>
							</svg>
						</span>
				</label>
			</div>

		</div>

			<div
				class="mt-3 rounded-[18px] border border-dashed border-stone-300 bg-stone-100/80 px-5 py-8 text-center dark:border-stone-700/80 dark:bg-stone-900/70"
			data-empty-state
			hidden
		>
					<h3 class="text-xl tracking-tight text-stone-900 sm:text-[2.125rem] dark:text-stone-100">
						{copy.photography.emptyStateTitle}
					</h3>
					<p class="mt-1.5 text-sm text-stone-500">
						{copy.photography.emptyStateDescription}
					</p>
			<button
				type="button"
				data-clear-all
					class="mt-6 inline-flex h-11 cursor-pointer items-center justify-center rounded-full border border-stone-300 bg-white px-5 text-sm font-medium text-stone-900 transition hover:border-stone-400 dark:border-stone-700 dark:bg-stone-800 dark:text-stone-100 dark:hover:border-stone-500 dark:hover:bg-stone-700"
				>
					{copy.photography.clearAllLabel}
				</button>
		</div>

		<div class="mt-3 grid grid-cols-1 gap-4 lg:grid-cols-2 xl:grid-cols-3 xl:gap-3" data-series-grid>
			{
				renderedSeries.map(
					({ entry, currentYear, shouldRenderDivider, searchIndex }) => {
					const flagSrc = resolveCountryFlag(entry.data.cardLocation);
					const countryLabel = resolveCountryLabel(entry.data.cardLocation, locale);
					const isCyprus = entry.data.cardLocation === "Cyprus";
					const cardCover = entry.data.cardCover ?? entry.data.cover;
					const cardCoverSrc = entry.data.cardCover
						? resolvePhotoAssetUrl(entry.data.cardCover.src, "card-cover")
						: resolvePhotoAssetUrl(entry.data.cover.src, "card-cover");

					return (
						<>
							{
								shouldRenderDivider && (
									<div
										data-year-divider
										data-year={currentYear}
										class="col-span-full flex items-center gap-3 py-5"
									>
										<span class="flex shrink-0 items-center gap-1">
											<svg
												xmlns="http://www.w3.org/2000/svg"
												viewBox="0 0 16 16"
												fill="currentColor"
												class="size-4 shrink-0 text-stone-500 dark:text-stone-400"
												aria-hidden="true"
											>
												<path
													fill-rule="evenodd"
													d="M8 2a.75.75 0 0 1 .75.75v8.69l1.22-1.22a.75.75 0 1 1 1.06 1.06l-2.5 2.5a.75.75 0 0 1-1.06 0l-2.5-2.5a.75.75 0 1 1 1.06-1.06l1.22 1.22V2.75A.75.75 0 0 1 8 2Z"
													clip-rule="evenodd"
												/>
											</svg>
											<span class="shrink-0 text-sm font-medium tracking-tight text-stone-500 dark:text-stone-400">
												{formatYearLabel(currentYear)}
											</span>
										</span>
										<span class="h-px w-full bg-stone-200/80 dark:bg-stone-800/80"></span>
									</div>
								)
							}
								<a
									href={localizePath(`/photography/${entry.data.slug}`, locale)}
									data-hover-card
								data-series-card
								data-country={entry.data.cardLocation}
								data-year={entry.data.year ? String(entry.data.year) : ""}
								data-sort-order={String(entry.data.sortOrder)}
								data-title={entry.data.title}
								data-search-index={searchIndex}
								class="group flex flex-col overflow-visible rounded-[12px] border border-stone-200/80 bg-white transition hover:border-stone-300"
							>
								<div class="overflow-hidden rounded-t-[12px] bg-stone-100">
									<img
										src={cardCoverSrc}
										alt={entry.data.title}
										width={cardCover.width}
										height={cardCover.height}
										class="aspect-[16/10] h-auto w-full object-cover transition duration-300 group-hover:scale-[1.02]"
									/>
								</div>
									<div class="min-w-0 p-5 xl:p-4">
										<p class="inline-flex flex-wrap items-center gap-2 text-sm text-stone-500 xl:text-[0.82rem]">
										<span class="inline-flex items-center gap-2">
											{
												flagSrc && (
													<span
														aria-label={countryLabel}
														role="img"
														data-flag-icon
														class="relative block h-[15px] w-5 shrink-0 overflow-visible"
													>
														<span class="tooltip tooltip--top" data-flag-tooltip aria-hidden="true">
															{countryLabel}
														</span>
														<img
															src={flagSrc}
															alt=""
															class="block size-full rounded-[2px] object-cover shadow-2xs"
														/>
														{isCyprus ? (
															<span class="pointer-events-none absolute inset-0 rounded-[2px] border border-stone-200/80"></span>
														) : (
															<span class="pointer-events-none absolute inset-0 rounded-[2px] border border-black/50 mix-blend-overlay"></span>
														)}
													</span>
												)
											}
										</span>
											<span>{formatPhotoTimeframe(entry.data.timeframe, locale)}</span>
											<span class="text-stone-500">·</span>
											<span>{copy.photography.framesLabel(entry.data.photos.length)}</span>
										</p>
										<div class="mt-px">
											<h2 class="min-w-0 text-xl tracking-tight text-stone-950 sm:text-2xl xl:text-[1.42rem]">
													{resolveLocalizedPhotoSeriesTitle(entry.data.title, locale)}
												</h2>
										</div>
								</div>
							</a>
						</>
					);
					}
				)
			}
		</div>
	</section>
</SiteLayout>

<script is:inline>
	(() => {
		const root = document.querySelector("[data-photography-root]");

		if (!(root instanceof HTMLElement)) {
			return;
		}

		const searchInput = root.querySelector("[data-photography-search]");
		const countrySelect = root.querySelector("[data-photography-country]");
		const yearSelect = root.querySelector("[data-photography-year]");
		const sortSelect = root.querySelector("[data-photography-sort]");
			const searchClearButton = root.querySelector("[data-search-clear]");
			const emptyState = root.querySelector("[data-empty-state]");
			const clearAllButton = root.querySelector("[data-clear-all]");
			const grid = root.querySelector("[data-series-grid]");
			const cards = Array.from(root.querySelectorAll("[data-series-card]")).filter(
				(card) => card instanceof HTMLAnchorElement
			);

		if (
			!(searchInput instanceof HTMLInputElement) ||
			!(countrySelect instanceof HTMLSelectElement) ||
			!(yearSelect instanceof HTMLSelectElement) ||
			!(sortSelect instanceof HTMLSelectElement) ||
			!(searchClearButton instanceof HTMLButtonElement) ||
			!(emptyState instanceof HTMLElement) ||
			!(clearAllButton instanceof HTMLButtonElement) ||
			!(grid instanceof HTMLElement)
		) {
			return;
		}

		const defaults = {
			q: "",
			country: "all",
			year: "all",
			sort: "newest"
		};

		const validCountries = new Set(
			Array.from(countrySelect.options).map((option) => option.value)
		);
			const validYears = new Set(
				Array.from(yearSelect.options).map((option) => option.value)
			);
		const validSorts = new Set(["newest", "oldest"]);
		const sortLabels = {
			newest: "Newest first",
			oldest: "Oldest first"
		};
		const searchDebounceMs = 150;

			const state = { ...defaults };
			const initialCardOrder = [...cards];
			let searchDebounceTimer = 0;

			const normalizeQuery = (value) => value.trim().replace(/\s+/g, " ").toLowerCase();
			const createYearDivider = (year) => {
				const divider = document.createElement("div");
				const group = document.createElement("span");
				const icon = document.createElementNS("http://www.w3.org/2000/svg", "svg");
				const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
				const label = document.createElement("span");
				const line = document.createElement("span");

				divider.dataset.yearDivider = "true";
				divider.dataset.year = year;
				divider.className = "col-span-full flex items-center gap-3 py-5";

				group.className = "flex shrink-0 items-center gap-1";

				icon.setAttribute("xmlns", "http://www.w3.org/2000/svg");
				icon.setAttribute("viewBox", "0 0 16 16");
				icon.setAttribute("fill", "currentColor");
				icon.setAttribute("class", "size-4 shrink-0 text-stone-500 dark:text-stone-400");
				icon.setAttribute("aria-hidden", "true");

				path.setAttribute("fill-rule", "evenodd");
				path.setAttribute(
					"d",
					"M8 2a.75.75 0 0 1 .75.75v8.69l1.22-1.22a.75.75 0 1 1 1.06 1.06l-2.5 2.5a.75.75 0 0 1-1.06 0l-2.5-2.5a.75.75 0 1 1 1.06-1.06l1.22 1.22V2.75A.75.75 0 0 1 8 2Z"
				);
				path.setAttribute("clip-rule", "evenodd");
				icon.append(path);

				label.className =
					"shrink-0 text-sm font-medium tracking-tight text-stone-500 dark:text-stone-400";
				label.textContent = year === "2003" ? "Legacy" : year;

				line.className = "h-px w-full bg-stone-200/80 dark:bg-stone-800/80";

				group.append(icon, label);
				divider.append(group, line);

				return divider;
			};

		const readUrlState = () => {
			const params = new URLSearchParams(window.location.search);
			const q = params.get("q") ?? defaults.q;
			const country = params.get("country") ?? defaults.country;
			const year = params.get("year") ?? defaults.year;
			const sort = params.get("sort") ?? defaults.sort;

			state.q = q;
			state.country = validCountries.has(country) ? country : defaults.country;
			state.year = validYears.has(year) ? year : defaults.year;
			state.sort = validSorts.has(sort) ? sort : defaults.sort;
		};

		const syncControls = () => {
			searchInput.value = state.q;
			countrySelect.value = state.country;
			yearSelect.value = state.year;
			sortSelect.value = state.sort;
			searchClearButton.classList.toggle("hidden", state.q.length === 0);
			searchClearButton.classList.toggle("flex", state.q.length > 0);
		};

		const syncUrl = () => {
			const params = new URLSearchParams();

			if (state.q) {
				params.set("q", state.q);
			}

			if (state.country !== defaults.country) {
				params.set("country", state.country);
			}

			if (state.year !== defaults.year) {
				params.set("year", state.year);
			}

			if (state.sort !== defaults.sort) {
				params.set("sort", state.sort);
			}

			const nextSearch = params.toString();
			const nextUrl = nextSearch
				? `${window.location.pathname}?${nextSearch}`
				: window.location.pathname;

			history.replaceState({}, "", nextUrl);
		};

		const getComparator = (sort) => {
			switch (sort) {
				case "oldest":
					return (left, right) =>
						Number.parseInt(left.dataset.sortOrder || "0", 10) -
						Number.parseInt(right.dataset.sortOrder || "0", 10);
				case "newest":
				default:
					return (left, right) =>
						Number.parseInt(right.dataset.sortOrder || "0", 10) -
						Number.parseInt(left.dataset.sortOrder || "0", 10);
			}
		};

		const applyState = () => {
			const query = normalizeQuery(state.q);
			const matchingCards = initialCardOrder.filter((card) => {
				const searchIndex = card.dataset.searchIndex || "";
				const matchesQuery = query ? searchIndex.includes(query) : true;
				const matchesCountry =
					state.country === defaults.country ||
					card.dataset.country === state.country;
				const matchesYear =
					state.year === defaults.year || card.dataset.year === state.year;

				return matchesQuery && matchesCountry && matchesYear;
			});

			const hiddenCards = initialCardOrder.filter(
				(card) => !matchingCards.includes(card)
			);

			matchingCards.sort(getComparator(state.sort));

			const visibleYears = Array.from(
				new Set(matchingCards.map((card) => card.dataset.year || ""))
			).filter(Boolean);
			const orderedYears = visibleYears.sort((left, right) =>
				state.sort === "oldest"
					? Number.parseInt(left, 10) - Number.parseInt(right, 10)
					: Number.parseInt(right, 10) - Number.parseInt(left, 10)
			);
			const cardsByYear = new Map();

			for (const card of matchingCards) {
				const year = card.dataset.year || "";
				const yearCards = cardsByYear.get(year) ?? [];
				yearCards.push(card);
				cardsByYear.set(year, yearCards);
			}

			for (const card of matchingCards) {
				card.hidden = false;
				card.setAttribute("aria-hidden", "false");
			}

			for (const card of hiddenCards) {
				card.hidden = true;
				card.setAttribute("aria-hidden", "true");
			}

			for (const divider of Array.from(grid.querySelectorAll("[data-year-divider]"))) {
				divider.remove();
			}

			const visibleItems = [];

			for (const year of orderedYears) {
				const yearCards = cardsByYear.get(year) ?? [];

				visibleItems.push(createYearDivider(year));
				visibleItems.push(...yearCards);
			}

			grid.append(...visibleItems, ...hiddenCards);
			emptyState.hidden = matchingCards.length > 0;
			grid.hidden = matchingCards.length === 0;
			syncUrl();
		};

		const cancelPendingSearchApply = () => {
			if (!searchDebounceTimer) {
				return;
			}

			window.clearTimeout(searchDebounceTimer);
			searchDebounceTimer = 0;
		};

		const applyStateImmediately = () => {
			cancelPendingSearchApply();
			applyState();
		};

		const scheduleSearchApplyState = () => {
			cancelPendingSearchApply();
			searchDebounceTimer = window.setTimeout(() => {
				searchDebounceTimer = 0;
				applyState();
			}, searchDebounceMs);
		};

		searchInput.addEventListener("input", () => {
			state.q = searchInput.value;
			searchClearButton.classList.toggle("hidden", state.q.length === 0);
			searchClearButton.classList.toggle("flex", state.q.length > 0);
			scheduleSearchApplyState();
		});

		searchClearButton.addEventListener("click", () => {
			state.q = defaults.q;
			syncControls();
			applyStateImmediately();
			searchInput.focus();
		});

		countrySelect.addEventListener("change", () => {
			state.country = countrySelect.value;
			applyStateImmediately();
		});

		yearSelect.addEventListener("change", () => {
			state.year = yearSelect.value;
			applyStateImmediately();
		});

		sortSelect.addEventListener("change", () => {
			state.sort = sortSelect.value;
			applyStateImmediately();
		});

		clearAllButton.addEventListener("click", () => {
			Object.assign(state, defaults);
			syncControls();
			applyStateImmediately();
		});

		readUrlState();
		syncControls();
		applyStateImmediately();
	})();
</script>
