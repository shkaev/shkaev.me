---
import SiteLayout from "../../layouts/SiteLayout.astro";
import MediaLinkCard from "../../components/sections/MediaLinkCard.astro";
import PageHero from "../../components/sections/PageHero.astro";
import { getSiteCopy } from "../../i18n/copy";
import { localizePath } from "../../i18n/routing";
import { resolveStaticAssetUrl } from "../../lib/assetUrl";

const locale = "ru" as const;
const copy = getSiteCopy(locale);

const resolvedCaseStudies = copy.design.caseStudies.map((study) => ({
	...study,
	href: localizePath(study.href, locale),
	logoSrc: resolveStaticAssetUrl(study.logoSrc),
	imageSrc: resolveStaticAssetUrl(study.imageSrc)
}));
---

<SiteLayout
	title={copy.design.metaTitle}
	description={copy.design.metaDescription}
	locale={locale}
>
	<div class="flex w-full flex-col">
		<PageHero
			eyebrow={copy.design.eyebrow}
			title={copy.design.title}
			lead={copy.design.lead}
		/>

		<section class="mt-8 w-full">
			<div class="flex flex-col gap-4">
				{
					resolvedCaseStudies.map((study) => (
						<MediaLinkCard
							href={study.href}
							title={study.title}
							logoSrc={study.logoSrc}
							imageSrc={study.imageSrc}
							imageAlt={study.imageAlt}
							description={study.description}
						/>
					))
				}
			</div>
		</section>
	</div>
</SiteLayout>
