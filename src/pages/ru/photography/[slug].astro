---
import { getCollection } from "astro:content";
import PhotoSeriesPage from "../../../components/photography/PhotoSeriesPage.astro";

export async function getStaticPaths() {
	const series = await getCollection("photo-series");

	return series.map((entry) => ({
		params: { slug: entry.data.slug },
		props: { entry }
	}));
}

const { entry } = Astro.props;
---

<PhotoSeriesPage entry={entry} locale="ru" />
