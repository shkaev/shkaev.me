---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
	title="Photography | Dima Shkaev"
	description="Photography collections and visual stories by Dima Shkaev."
>
	<section class="max-w-3xl">
		<p class="text-sm font-medium uppercase tracking-[0.24em] text-stone-500">
			Photography
		</p>
		<h1 class="mt-6 text-4xl font-normal tracking-tight text-stone-950 sm:text-5xl">
			Selected collections are coming here next.
		</h1>
		<p class="mt-8 max-w-2xl text-base leading-8 text-stone-600 sm:text-lg">
			This section will feature curated photo series, archived over time and
			organized into distinct visual narratives.
		</p>
	</section>
</SiteLayout>
