---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
	title="Photography | Dmitry Shkaev"
	description="Photography collections and visual stories by Dmitry Shkaev."
>
	<section class="w-full">
		<p class="text-sm font-medium uppercase tracking-[0.24em] text-stone-500">
			Photography
		</p>
		<h1 class="mt-6 text-4xl font-normal tracking-tight text-balance text-stone-950 sm:text-5xl md:text-6xl">
			Selected collections are coming here next.
		</h1>
		<p class="mt-5 text-base leading-8 text-stone-700 sm:text-lg">
			This section will feature curated photo series, archived over time and
			organized into distinct visual narratives.
		</p>
	</section>
</SiteLayout>
