---
import { getCollection } from "astro:content";
import SiteLayout from "../layouts/SiteLayout.astro";
import { resolvePhotoAssetUrl } from "../lib/photoAsset";

const series = (await getCollection("photo-series")).sort(
	(a, b) => b.data.sortOrder - a.data.sortOrder
);
const countryFlagByLocation: Record<string, string> = {
	Cyprus: "/images/flags/cyprus.svg",
	Kazakhstan: "/images/flags/kazakhstan.svg",
	Uzbekistan: "/images/flags/uzbekistan.svg",
	Russia: "/images/flags/russia.svg",
	UAE: "/images/flags/uae.svg",
	"United Arab Emirates": "/images/flags/uae.svg"
};
const resolveCountryFlag = (location: string) => countryFlagByLocation[location];

---

<SiteLayout
	title="Photography | Dmitry Shkaev"
	description="Photography collections and visual stories by Dmitry Shkaev."
>
	<section class="w-full">
		<p class="text-sm font-medium uppercase tracking-[0.24em] text-stone-500">
			Photography
		</p>
		<h1 class="mt-4 text-4xl font-normal tracking-tight text-balance text-stone-950 sm:mt-6 sm:text-5xl md:text-6xl">
			My collection
		</h1>
		<p class="mt-5 text-base leading-8 text-stone-700 sm:text-lg">
			This is an archive of photos taken with my Fujifilm X-E4. It’s
			built series by series, with every collection kept in sequence to
			preserve the feeling of time, place, and movement.
		</p>

		<div class="mt-8 grid grid-cols-1 gap-4 xl:grid-cols-2">
			{
				series.map((entry) => {
					const flagSrc = resolveCountryFlag(entry.data.cardLocation);
					const isCyprus = entry.data.cardLocation === "Cyprus";
					const cardCover = entry.data.cardCover ?? entry.data.cover;
					const cardCoverSrc = entry.data.cardCover
						? resolvePhotoAssetUrl(entry.data.cardCover.src, "card-cover")
						: resolvePhotoAssetUrl(entry.data.cover.src, "card-cover");

					return (
						<a
							href={`/photography/${entry.data.slug}`}
							data-hover-card
							class="group flex flex-col overflow-visible rounded-[12px] border border-stone-200/80 bg-white transition hover:border-stone-300"
						>
							<div class="overflow-hidden rounded-t-[12px] bg-stone-100">
								<img
									src={cardCoverSrc}
									alt={entry.data.title}
									width={cardCover.width}
									height={cardCover.height}
									class="aspect-[16/10] h-auto w-full object-cover transition duration-300 group-hover:scale-[1.02]"
								/>
							</div>
							<div class="min-w-0 p-6">
								<p class="inline-flex flex-wrap items-center gap-2 text-sm text-stone-500">
									<span class="inline-flex items-center gap-2">
										{
											flagSrc && (
												<span
													aria-label={entry.data.cardLocation}
													role="img"
													data-flag-icon
													class="relative block h-[15px] w-5 shrink-0 overflow-visible"
												>
													<span data-flag-tooltip aria-hidden="true">
														{entry.data.cardLocation}
													</span>
													<img
														src={flagSrc}
														alt=""
														class="block size-full rounded-[2px] object-cover shadow-2xs"
													/>
													{isCyprus ? (
														<span class="pointer-events-none absolute inset-0 rounded-[2px] border border-stone-200/80"></span>
													) : (
														<span class="pointer-events-none absolute inset-0 rounded-[2px] border border-black/50 mix-blend-overlay"></span>
													)}
												</span>
											)
										}
									</span>
									<span>{entry.data.timeframe}</span>
									<span class="text-stone-500">·</span>
									<span>{entry.data.photos.length} frames</span>
								</p>
								<div class="mt-px">
									<h2 class="min-w-0 text-xl tracking-tight text-stone-950 sm:text-2xl">
										{entry.data.title}
									</h2>
								</div>
							</div>
						</a>
					);
				})
			}
		</div>
	</section>
</SiteLayout>
