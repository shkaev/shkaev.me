---
import SiteLayout from "../layouts/SiteLayout.astro";
import MediaLinkCard from "../components/sections/MediaLinkCard.astro";
import PageHero from "../components/sections/PageHero.astro";
import { getCaseStudyCards } from "../case-studies/en";
import { playgroundSection } from "../design/playground";
import { getSiteCopy } from "../i18n/copy";
import { localizePath } from "../i18n/routing";
import { resolveStaticAssetUrl } from "../lib/assetUrl";

const locale = "en" as const;
const copy = getSiteCopy(locale);

const resolvedCaseStudies = getCaseStudyCards().map((study) => ({
	...study,
	href: localizePath(study.href, locale),
	logoSrc: resolveStaticAssetUrl(study.logoSrc),
	imageSrc: resolveStaticAssetUrl(study.imageSrc)
}));

const resolvedPlaygroundSection = {
	...playgroundSection,
	cards: playgroundSection.cards.map((card) => ({
		...card,
		imageSrc: resolveStaticAssetUrl(card.imageSrc)
	}))
};
---

<SiteLayout
	title={copy.design.metaTitle}
	description={copy.design.metaDescription}
	locale={locale}
>
	<div class="flex w-full flex-col">
		<div class="w-full max-w-[60rem]">
			<PageHero
				eyebrow={copy.design.eyebrow}
				title={copy.design.title}
				lead={copy.design.lead}
			/>
		</div>
		<section class="mt-8 w-full">
			<div class="flex flex-col gap-4">
				{
					resolvedCaseStudies.map((study) => (
						<MediaLinkCard
							href={study.href}
							title={study.title}
							logoSrc={study.logoSrc}
							imageSrc={study.imageSrc}
							imageAlt={study.imageAlt}
							description={study.description}
						/>
					))
				}
			</div>
		</section>
		<section class="mt-16 w-full sm:mt-20">
			<div class="w-full max-w-[60rem]">
				<PageHero
					title={resolvedPlaygroundSection.title}
					lead={resolvedPlaygroundSection.lead}
				/>
			</div>
			<div class="mt-8 flex flex-col gap-4">
				{
					resolvedPlaygroundSection.cards.map((entry) => (
						<MediaLinkCard
							href={entry.href}
							title={entry.title}
							imageSrc={entry.imageSrc}
							imageAlt={entry.imageAlt}
							description={entry.description}
						/>
					))
				}
			</div>
		</section>
	</div>
</SiteLayout>
