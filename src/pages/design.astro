---
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout
	title="Design | Dima Shkaev"
	description="Product design highlights and selected work by Dima Shkaev."
>
	<section class="max-w-3xl">
		<p class="text-sm font-medium uppercase tracking-[0.24em] text-stone-500">
			Design
		</p>
		<h1 class="mt-6 text-4xl font-normal tracking-tight text-stone-950 sm:text-5xl">
			Product design highlights will live here.
		</h1>
		<p class="mt-8 max-w-2xl text-base leading-8 text-stone-600 sm:text-lg">
			For now this page is a placeholder for selected case studies, process
			snapshots, and notable milestones from my professional work.
		</p>
	</section>
</SiteLayout>
