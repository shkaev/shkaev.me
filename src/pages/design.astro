---
import SiteLayout from "../layouts/SiteLayout.astro";
import ChevronRightIcon from "../components/icons/ChevronRightIcon.astro";

const caseStudies = [
	{
		href: "/design/case-studies/aosp",
		title: "Avast Online Security & Privacy",
		imageSrc: "/images/case-studies/aosp/aosp-hero.jpg",
		imageAlt: "Avast Online Security & Privacy case study preview",
		description:
			"A major redesign of the flagship browser extension with over 10 million users."
	},
	{
		href: "/design/case-studies/cookie-manager",
		title: "Cookie Manager",
		imageSrc: "/images/case-studies/cookie-manager/cookie-manager-hero.jpg",
		imageAlt: "Cookie Manager case study preview",
		description:
			"Designing, building, and integrating a new feature in Avast Online Security & Privacy."
	},
	{
		href: "/design/case-studies/trackoff",
		title: "TrackOFF",
		imageSrc: "/images/case-studies/trackoff/trackoff-hero.jpg",
		imageAlt: "TrackOFF case study preview",
		description:
			"A short story about creating a successful product from the ground up to being acquired by a major corporation."
	}
];
---

<SiteLayout
	title="Design | Dmitry Shkaev"
	description="Product design highlights and selected work by Dmitry Shkaev."
>
	<div class="flex w-full flex-col">
		<section class="w-full">
			<p class="text-sm font-medium uppercase tracking-[0.24em] text-stone-500">
				Design
			</p>
			<h1 class="mt-6 text-4xl font-normal tracking-tight text-balance text-stone-950 sm:text-5xl md:text-6xl">
				Case studies
			</h1>
			<p class="mt-5 text-base leading-8 text-stone-700 sm:text-lg">
				Explore some of the featured product design work I've been doing over
				the years.
			</p>
		</section>

		<section class="mt-10 w-full">
			<div class="flex flex-col gap-4">
				{
					caseStudies.map((study) => (
						<a
							href={study.href}
							data-hover-card
							class="group grid w-full grid-cols-[6.5rem_minmax(0,1fr)_2.5rem] items-center gap-x-4 rounded-[12px] border border-stone-200/70 bg-white p-3 shadow-[0_1px_0_rgba(28,25,23,0.04)] transition-colors hover:border-stone-300/80 sm:grid-cols-[9rem_minmax(0,1fr)_2.5rem] sm:gap-x-5 sm:p-4"
						>
							<div class="overflow-hidden rounded-[8px] border border-stone-200/80 bg-stone-100">
								<img
									src={study.imageSrc}
									alt={study.imageAlt}
									class="block h-auto w-full transition-transform duration-300 ease-out group-hover:scale-[1.08]"
									loading="lazy"
								/>
							</div>
							<div class="min-w-0">
								<h4 class="text-xl tracking-tight text-stone-950 sm:text-2xl">
									{study.title}
								</h4>
								<p class="mt-1 text-xs leading-5 text-stone-700 sm:text-sm">
									{study.description}
								</p>
							</div>
							<span data-card-accent class="flex h-10 w-10 items-center justify-center self-center text-stone-400 transition group-hover:text-stone-700">
									<ChevronRightIcon class="h-5 w-5" />
							</span>
						</a>
					))
				}
			</div>
		</section>
	</div>
</SiteLayout>
