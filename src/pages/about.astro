const visibleWorkTimeline = workTimeline.slice(0, 3);
const hiddenWorkTimeline = workTimeline.slice(3);
const featuredRecommendation = recommendations[0];
const recommendationSliderItems = recommendations.map((item) => ({
	name: item.name,
	href: item.href,
	favicon: item.favicon ?? "",
	role: item.role,
	avatar: item.avatar ?? "",
	text: item.text
}));

const escapeRecommendationHtml = (value: string) =>
	value
		.replaceAll("&", "&amp;")
		.replaceAll("<", "&lt;")
		.replaceAll(">", "&gt;")
		.replaceAll('"', "&quot;")
		.replaceAll("'", "&#39;");

const renderRecommendationQuote = (value: string) =>
	escapeRecommendationHtml(value).replaceAll(
		"[...]",
		'<span class="text-stone-300 dark:text-stone-700">[...]</span>'
	);
