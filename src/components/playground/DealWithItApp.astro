---
import { DEAL_WITH_IT_GLASSES, type DealWithItAppConfig, type DealWithItCopy } from "../../scripts/deal-with-it/shared";

interface Props {
	locale: "en" | "ru";
	backHref: string;
}

const { locale, backHref } = Astro.props;

const dogGifSrc = "/images/playground/deal-with-it-dog.gif";
const glasses = DEAL_WITH_IT_GLASSES.map((item) => ({
	...item,
	src: `/images/playground/deal-with-it/${item.fileName}`
}));

const copy: Record<"en" | "ru", DealWithItCopy> = {
	en: {
		uploadButton: "Pick a photo",
		uploadButtonBusy: "Preparing…",
		uploadHelper: "JPG or PNG, up to 10 MB.",
		uploadPrivacyNote: "Your photo is processed locally in your browser.<br />Nothing is uploaded or stored.",
		invalidTypeError: "Please upload a JPG or PNG image.",
		fileTooLargeError: "The file must be 10 MB or smaller.",
		noFaceError: "We couldn’t detect a face in this photo. Please try another one.",
		processingError: "Something went wrong while preparing the photo. Please try again.",
		createGifButton: "Create GIF",
		createGifButtonBusy: "Creating…",
		uploadNewPhotoButton: "← Upload new photo",
		resultTitle: "Bravo! You created this GIF.",
		makeAnotherOneButton: "Make another one",
		downloadButton: "Download",
		generationError: "We couldn’t create the GIF. Please try again.",
		backLabel: "Go back"
	},
	ru: {
		uploadButton: "Выберите фото",
		uploadButtonBusy: "Подготавливаем…",
		uploadHelper: "JPG или PNG, не больше 10 MB.",
		uploadPrivacyNote: "Фото обрабатывается локально в браузере.<br />Ничего не загружается и не хранится.",
		invalidTypeError: "Загрузите изображение в формате JPG или PNG.",
		fileTooLargeError: "Файл должен быть не больше 10 MB.",
		noFaceError: "Мы не смогли определить лицо на этом фото. Попробуйте другое.",
		processingError: "Не удалось подготовить фото. Попробуйте ещё раз.",
		createGifButton: "Создать GIF",
		createGifButtonBusy: "Создаём…",
		uploadNewPhotoButton: "← Загрузить другое фото",
		resultTitle: "Браво! Гифка готова.",
		makeAnotherOneButton: "Сделать ещё одну",
		downloadButton: "Скачать",
		generationError: "Не удалось создать GIF. Попробуйте ещё раз.",
		backLabel: "Назад"
	}
};

const config: DealWithItAppConfig = {
	locale,
	backHref,
	dogGifSrc,
	glasses,
	copy: copy[locale]
};

const actionButtonBaseClass =
	"group relative inline-flex min-h-[4.5rem] w-full cursor-pointer items-center justify-center overflow-hidden rounded-full border px-7 py-4 transition duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] active:scale-[0.985] disabled:cursor-default disabled:opacity-60";

const primaryButtonClass = `${actionButtonBaseClass} border-[#f4d48d]/55 bg-[linear-gradient(180deg,#f4c96a_0%,#e5a934_100%)] text-[#21160b] shadow-[0_18px_36px_rgba(229,169,52,0.28),0_6px_0_rgba(132,79,19,0.55)] hover:-translate-y-0.5 hover:brightness-[1.03] hover:shadow-[0_24px_46px_rgba(229,169,52,0.34),0_7px_0_rgba(132,79,19,0.55)] active:translate-y-[2px] active:shadow-[0_12px_24px_rgba(229,169,52,0.25),0_3px_0_rgba(132,79,19,0.55)]`;

const secondaryButtonClass = `${actionButtonBaseClass} border-stone-500/30 bg-[linear-gradient(180deg,#2b2927_0%,#171412_100%)] text-stone-50 shadow-[0_16px_34px_rgba(0,0,0,0.24),0_5px_0_rgba(68,64,60,0.8)] hover:-translate-y-0.5 hover:border-stone-400 hover:brightness-[1.04] hover:shadow-[0_22px_42px_rgba(0,0,0,0.3),0_6px_0_rgba(68,64,60,0.8)] active:translate-y-[2px] active:shadow-[0_12px_24px_rgba(0,0,0,0.22),0_2px_0_rgba(68,64,60,0.8)]`;

const buttonChromeClass =
	"pointer-events-none absolute inset-[1px] rounded-full border border-white/18 shadow-[inset_0_1px_0_rgba(255,255,255,0.24)]";

const primaryButtonChromeClass =
	"pointer-events-none absolute inset-[1px] rounded-full";

const buttonLabelClass =
	"relative inline-flex w-full items-center justify-center gap-2 font-['Press_Start_2P','IBM_Plex_Mono','SF_Mono','Cascadia_Mono','Menlo','Monaco',monospace] text-current text-[1.2rem] leading-[1.3] drop-shadow-[0_1px_0_rgba(255,255,255,0.12)]";

const primaryButtonLabelClass =
	`${buttonLabelClass}`;

const helperTextClass =
	"mt-2 max-w-[26rem] text-center text-sm leading-6 text-stone-950 dark:text-stone-50";

const privacyBubbleClass =
	"relative mt-6 max-w-[28rem] rounded-[1.1rem] border border-stone-400/80 bg-white/92 px-4 py-3 text-center text-[0.92rem] leading-6 text-stone-700 shadow-[0_10px_24px_rgba(28,25,23,0.08)] dark:border-stone-700/90 dark:bg-zinc-900/92 dark:text-stone-300";

const errorTextClass =
	"text-center text-sm leading-6 text-red-700 dark:text-red-300";

const glassesButtonClass =
	"group inline-flex aspect-square cursor-pointer items-center justify-center rounded-[0.875rem] border border-stone-700/90 bg-[linear-gradient(180deg,rgba(24,24,24,0.96)_0%,rgba(14,14,14,0.98)_100%)] p-2.5 shadow-[0_12px_24px_rgba(0,0,0,0.18)] transition duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-0.5 hover:border-stone-500 hover:shadow-[0_18px_32px_rgba(0,0,0,0.24)] data-[selected=true]:border-stone-100/85 data-[selected=true]:shadow-[0_18px_36px_rgba(255,255,255,0.08)]";
---

<div class="dwi-root" data-deal-with-it-root>
	<script
		type="application/json"
		data-deal-with-it-config
		set:html={JSON.stringify(config)}
	></script>

	<a href={backHref} aria-label={copy[locale].backLabel} class="dwi-close-link">
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
			<path d="M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"></path>
			<path d="M18 6 6 18" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	</a>

	<section class="dwi-screen dwi-screen--upload" data-step-upload>
		<div class="dwi-upload-title-wrap" aria-hidden="true">
			<svg class="dwi-title-rays" viewBox="0 0 1600 700" preserveAspectRatio="xMidYMin slice">
				<defs>
					<linearGradient id="dwi-ray-pink" x1="0" y1="0" x2="0" y2="1">
						<stop offset="0%" stop-color="#ff4f9a" stop-opacity="0.95" />
						<stop offset="100%" stop-color="#ff4f9a" stop-opacity="0" />
					</linearGradient>
					<linearGradient id="dwi-ray-cyan" x1="0" y1="0" x2="0" y2="1">
						<stop offset="0%" stop-color="#6af6ff" stop-opacity="0.92" />
						<stop offset="100%" stop-color="#6af6ff" stop-opacity="0" />
					</linearGradient>
					<linearGradient id="dwi-ray-yellow" x1="0" y1="0" x2="0" y2="1">
						<stop offset="0%" stop-color="#ffe36d" stop-opacity="0.88" />
						<stop offset="100%" stop-color="#ffe36d" stop-opacity="0" />
					</linearGradient>
					<filter id="dwi-ray-glow" x="-20%" y="-20%" width="140%" height="140%">
						<feGaussianBlur stdDeviation="8" result="blur" />
						<feMerge>
							<feMergeNode in="blur" />
							<feMergeNode in="SourceGraphic" />
						</feMerge>
					</filter>
				</defs>
				<g filter="url(#dwi-ray-glow)">
					<polygon class="dwi-ray dwi-ray--g" points="800,0 190,700 300,700" fill="url(#dwi-ray-cyan)" />
					<polygon class="dwi-ray dwi-ray--a" points="800,0 335,700 445,700" fill="url(#dwi-ray-pink)" />
					<polygon class="dwi-ray dwi-ray--b" points="800,0 480,700 590,700" fill="url(#dwi-ray-yellow)" />
					<polygon class="dwi-ray dwi-ray--c" points="800,0 665,700 775,700" fill="url(#dwi-ray-cyan)" />
					<polygon class="dwi-ray dwi-ray--d" points="800,0 825,700 935,700" fill="url(#dwi-ray-pink)" />
					<polygon class="dwi-ray dwi-ray--e" points="800,0 1010,700 1120,700" fill="url(#dwi-ray-yellow)" />
					<polygon class="dwi-ray dwi-ray--f" points="800,0 1155,700 1265,700" fill="url(#dwi-ray-cyan)" />
					<polygon class="dwi-ray dwi-ray--h" points="800,0 1300,700 1410,700" fill="url(#dwi-ray-pink)" />
				</g>
				<circle class="dwi-ray-core" cx="800" cy="0" r="72" />
			</svg>
			<h1 class="dwi-title text-center text-[clamp(3.4rem,11vw,7.8rem)] uppercase leading-[0.78]">DEAL WITH IT</h1>
		</div>
		<div class="dwi-upload-stack">
			<img src={dogGifSrc} alt="" class="dwi-dog" data-dog-gif />
			<div class="dwi-upload-controls">
				<input data-upload-input class="dwi-upload-input" type="file" accept="image/jpeg,image/png,.jpg,.jpeg,.png" />
				<button data-upload-button class={primaryButtonClass} type="button">
					<span class={primaryButtonChromeClass}></span>
					<span class={primaryButtonLabelClass} data-upload-button-label>{copy[locale].uploadButton}</span>
				</button>
				<div class="dwi-upload-notes">
					<p class={helperTextClass}>{copy[locale].uploadHelper}</p>
					<p class={`${privacyBubbleClass} dwi-privacy-bubble`}>
						<span class="dwi-speech-tail"></span>
						<Fragment set:html={copy[locale].uploadPrivacyNote} />
					</p>
				</div>
				<p class={errorTextClass} data-upload-error hidden></p>
			</div>
		</div>
	</section>

	<section class="dwi-screen" data-step-editor hidden>
		<div class="dwi-editor-stack">
			<div class="dwi-editor-stage">
				<div class="dwi-slider-column dwi-slider-column--left">
					<span class="dwi-slider-midpoint" aria-hidden="true"></span>
					<input
						id="dwi-scale-slider"
						data-scale-slider
						class="dwi-vertical-slider"
						type="range"
						min="-100"
						max="100"
						step="1"
						value="0"
					/>
				</div>
				<div class="dwi-preview-frame" data-preview-frame>
					<img data-preview-image class="dwi-preview-image" alt="" />
					<img data-preview-overlay class="dwi-preview-overlay" alt="" />
				</div>
				<div class="dwi-slider-column dwi-slider-column--right">
					<span class="dwi-slider-midpoint" aria-hidden="true"></span>
					<input
						id="dwi-rotation-slider"
						data-rotation-slider
						class="dwi-vertical-slider"
						type="range"
						min="-15"
						max="15"
						step="1"
						value="0"
					/>
				</div>
			</div>
			<div class="dwi-glasses-grid">
				{
					glasses.map((item) => (
						<button
							type="button"
							class={glassesButtonClass}
							data-glasses-button={item.id}
							data-selected={item.id === glasses[0].id ? "true" : "false"}
						>
							<img src={item.src} alt="" />
						</button>
					))
				}
			</div>
			<div class="dwi-action-row">
				<button data-upload-new-button class={secondaryButtonClass} type="button">
					<span class={buttonChromeClass}></span>
					<span class={buttonLabelClass}>{copy[locale].uploadNewPhotoButton}</span>
				</button>
				<button data-create-gif-button class={primaryButtonClass} type="button">
					<span class={primaryButtonChromeClass}></span>
					<span class={primaryButtonLabelClass} data-create-gif-button-label>{copy[locale].createGifButton}</span>
				</button>
			</div>
			<p class={`${errorTextClass} dwi-error--editor`} data-editor-error hidden></p>
		</div>
	</section>

	<section class="dwi-screen" data-step-result hidden>
		<div class="dwi-result-stack">
			<h1 class="font-display text-3xl text-center tracking-tight text-stone-950 sm:text-4xl dark:text-stone-50">{copy[locale].resultTitle}</h1>
			<img data-result-image class="dwi-result-image" alt="" />
			<div class="dwi-action-row">
				<button data-restart-button class={secondaryButtonClass} type="button">
					<span class={buttonChromeClass}></span>
					<span class={buttonLabelClass}>{copy[locale].makeAnotherOneButton}</span>
				</button>
				<button data-download-button class={primaryButtonClass} type="button">
					<span class={primaryButtonChromeClass}></span>
					<span class={buttonLabelClass}>{copy[locale].downloadButton}</span>
				</button>
			</div>
		</div>
	</section>
</div>

<style>
	:root {
		--dwi-page-bg: #fafaf9;
		--dwi-page-fg: #1c1917;
		--dwi-control-color: #78716c;
		--dwi-control-hover: #44403c;
		--dwi-surface: rgba(255, 255, 255, 0.74);
		--dwi-surface-line: rgba(214, 211, 209, 0.88);
		--dwi-surface-strong: rgba(255, 255, 255, 0.92);
		--dwi-button-primary-bg: #1c1917;
		--dwi-button-primary-fg: #fafaf9;
		--dwi-button-secondary-bg: rgba(255, 255, 255, 0.78);
		--dwi-button-secondary-fg: #1c1917;
		--dwi-button-secondary-line: rgba(214, 211, 209, 0.92);
		--dwi-error: #b91c1c;
		--dwi-preview-size: 400px;
	}

	html.dark {
		--dwi-page-bg: #0c0a09;
		--dwi-page-fg: #f5f5f4;
		--dwi-control-color: #a8a29e;
		--dwi-control-hover: #e7e5e4;
		--dwi-surface: rgba(28, 25, 23, 0.82);
		--dwi-surface-line: rgba(68, 64, 60, 0.95);
		--dwi-surface-strong: rgba(28, 25, 23, 0.95);
		--dwi-button-primary-bg: #fafaf9;
		--dwi-button-primary-fg: #1c1917;
		--dwi-button-secondary-bg: rgba(28, 25, 23, 0.85);
		--dwi-button-secondary-fg: #f5f5f4;
		--dwi-button-secondary-line: rgba(87, 83, 78, 0.95);
		--dwi-error: #fca5a5;
	}

	.dwi-root {
		min-height: 100vh;
		background:
			radial-gradient(circle at top, rgba(120, 113, 108, 0.09), transparent 32%),
			var(--dwi-page-bg);
		color: var(--dwi-page-fg);
	}

	.dwi-close-link {
		position: fixed;
		top: 1.5rem;
		right: 1.5rem;
		z-index: 10;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3rem;
		height: 3rem;
		color: var(--dwi-control-color);
		text-decoration: none;
		transition:
			transform 220ms cubic-bezier(0.16, 1, 0.3, 1),
			color 180ms cubic-bezier(0.16, 1, 0.3, 1);
	}

	.dwi-close-link:hover {
		color: var(--dwi-control-hover);
		transform: scale(1.04);
	}

	.dwi-close-link:active {
		transform: scale(0.96);
	}

	.dwi-close-link:focus-visible {
		outline: none;
		color: var(--dwi-control-hover);
	}

	.dwi-close-link svg {
		width: clamp(1.45rem, 3vw, 2.1rem);
		height: clamp(1.45rem, 3vw, 2.1rem);
		flex: none;
		stroke-width: 1.2;
	}

	.dwi-screen {
		display: grid;
		min-height: 100vh;
		place-items: center;
		padding: 2rem 1.5rem;
	}

	.dwi-screen--upload {
		position: relative;
		overflow: hidden;
	}

	.dwi-screen[hidden] {
		display: none;
	}

	.dwi-upload-stack,
	.dwi-editor-stack,
	.dwi-result-stack {
		width: min(100%, 56rem);
		display: grid;
		justify-items: center;
	}

	.dwi-upload-stack {
		position: relative;
		z-index: 1;
		width: min(100%, 72rem);
		gap: 2.25rem;
	}

	.dwi-upload-title-wrap {
		position: absolute;
		left: 50%;
		top: 6.75rem;
		z-index: 1;
		display: flex;
		justify-content: center;
		width: min(100%, 86rem);
		pointer-events: none;
		transform: translateX(-50%);
		perspective: 1200px;
	}

	.dwi-title-rays {
		position: absolute;
		left: 50%;
		top: -7rem;
		width: min(100vw, 96rem);
		height: 56rem;
		transform: translateX(-50%);
		overflow: visible;
		pointer-events: none;
		mix-blend-mode: screen;
	}

	.dwi-title-stack {
		position: relative;
		display: grid;
		place-items: center;
		perspective: 1200px;
		transform-style: preserve-3d;
	}

	.dwi-ray {
		opacity: 0.82;
		animation: dwi-ray-flicker 3.8s ease-in-out infinite;
	}

	.dwi-ray--a { animation-delay: 0s; }
	.dwi-ray--b { animation-delay: 0.35s; }
	.dwi-ray--c { animation-delay: 0.7s; }
	.dwi-ray--d { animation-delay: 1.05s; }
	.dwi-ray--e { animation-delay: 1.4s; }
	.dwi-ray--f { animation-delay: 1.75s; }
	.dwi-ray--g { animation-delay: 2.1s; }
	.dwi-ray--h { animation-delay: 2.45s; }

	.dwi-ray-core {
		fill: #ffe36d;
		filter: blur(12px);
		opacity: 0.88;
		animation:
			dwi-ray-core-pulse 4.2s ease-in-out infinite alternate,
			dwi-ray-core-color 7.5s linear infinite;
	}

	.dwi-title {
		position: relative;
		margin: 0;
		white-space: nowrap;
		font-family: "Rubik Broken Fax", "IBM Plex Serif", serif;
		font-weight: 400;
		letter-spacing: 0.04em;
		color: transparent;
		background-image: linear-gradient(
			115deg,
			#ff3d81 0%,
			#ff9a2f 18%,
			#ffe36d 34%,
			#59f0ff 52%,
			#7d7dff 70%,
			#ff3d81 100%
		);
		background-size: 220% 220%;
		background-clip: text;
		-webkit-background-clip: text;
		transform-style: preserve-3d;
		animation:
			dwi-title-shift 5.5s linear infinite,
			dwi-title-drift 18s cubic-bezier(0.42, 0, 0.58, 1) infinite alternate;
	}

	.dwi-title-trail {
		position: absolute;
		inset: 0;
		display: grid;
		place-items: center;
		white-space: nowrap;
		font-family: "Rubik Broken Fax", "IBM Plex Serif", serif;
		font-weight: 400;
		letter-spacing: 0.04em;
		pointer-events: none;
	}

	.dwi-title-trail--a {
		z-index: 0;
		color: rgba(255, 61, 129, 0.92);
		transform: translate3d(0.08em, 0.1em, -18px) rotateZ(-0.5deg);
		animation: dwi-title-trail-a 18s cubic-bezier(0.42, 0, 0.58, 1) infinite alternate;
	}

	.dwi-title-trail--b {
		z-index: -1;
		color: rgba(89, 240, 255, 0.88);
		transform: translate3d(-0.08em, 0.14em, -34px) rotateZ(0.55deg);
		animation: dwi-title-trail-b 18s cubic-bezier(0.42, 0, 0.58, 1) infinite alternate;
	}

	.dwi-title-trail--c {
		z-index: -2;
		color: rgba(255, 227, 109, 0.76);
		transform: translate3d(0.02em, 0.18em, -48px) rotateZ(-0.35deg);
		animation: dwi-title-trail-c 18s cubic-bezier(0.42, 0, 0.58, 1) infinite alternate;
	}

	.dwi-editor-stack {
		gap: 1.25rem;
	}

	.dwi-result-stack {
		gap: 1.5rem;
		width: min(100%, 64rem);
	}

	.dwi-dog {
		display: block;
		width: min(100%, 14rem);
		height: auto;
	}

	.dwi-upload-controls {
		display: grid;
		width: min(100%, 28rem);
		justify-items: center;
		gap: 1.15rem;
	}

	.dwi-upload-notes {
		display: grid;
		justify-items: center;
		gap: 2rem;
	}

	.dwi-upload-input {
		position: absolute;
		opacity: 0;
		pointer-events: none;
	}

	.dwi-upload-controls p,
	.dwi-editor-stack > p {
		margin: 0;
	}

	.dwi-error--editor {
		max-width: 28rem;
	}

	.dwi-speech-tail {
		position: absolute;
		left: 50%;
		top: -0.5rem;
		bottom: auto;
		z-index: 1;
		width: 0.85rem;
		height: 0.85rem;
		border-top: 1px solid rgba(168, 162, 158, 0.8);
		border-right: 1px solid rgba(168, 162, 158, 0.8);
		background: inherit;
		transform: translateX(-50%) rotate(-45deg);
	}

	:global(.dark) .dwi-speech-tail {
		border-top-color: rgba(68, 64, 60, 0.9);
		border-right-color: rgba(68, 64, 60, 0.9);
	}

	.dwi-preview-frame {
		position: relative;
		width: var(--dwi-preview-size);
		height: var(--dwi-preview-size);
		aspect-ratio: 1;
		border-radius: 1.5rem;
		background: var(--dwi-surface);
		border: 1px solid var(--dwi-surface-line);
		box-shadow: 0 18px 48px rgba(28, 25, 23, 0.08);
		overflow: hidden;
		backdrop-filter: blur(10px);
	}

	.dwi-editor-stage {
		display: grid;
		grid-template-columns: 2.75rem var(--dwi-preview-size) 2.75rem;
		align-items: center;
		gap: 0.75rem;
		width: fit-content;
		max-width: 100%;
		justify-content: center;
	}

	.dwi-slider-column {
		position: relative;
		width: 2.75rem;
		height: var(--dwi-preview-size);
		display: block;
		overflow: visible;
	}

	.dwi-slider-midpoint {
