---
import { DEAL_WITH_IT_GLASSES, type DealWithItAppConfig, type DealWithItCopy } from "../../scripts/deal-with-it/shared";

interface Props {
	locale: "en" | "ru";
	backHref: string;
}

const { locale, backHref } = Astro.props;

const dogGifSrc = "/images/playground/deal-with-it-dog.gif";
const glasses = DEAL_WITH_IT_GLASSES.map((item) => ({
	...item,
	src: `/images/playground/deal-with-it/${item.fileName}`
}));

const copy: Record<"en" | "ru", DealWithItCopy> = {
	en: {
		uploadButton: "Pick a photo",
		uploadButtonBusy: "Preparing…",
		uploadHelper: "JPG or PNG, up to 10 MB.",
		uploadPrivacyNote: "Your photo is processed locally in your browser.<br />Nothing is uploaded or stored.",
		invalidTypeError: "Please upload a JPG or PNG image.",
		fileTooLargeError: "The file must be 10 MB or smaller.",
		noFaceError: "We couldn’t detect a face in this photo. Please try another one.",
		processingError: "Something went wrong while preparing the photo. Please try again.",
		createGifButton: "Create GIF",
		createGifButtonBusy: "Creating…",
		uploadNewPhotoButton: "← Upload new photo",
		resultTitleLead: "Bravo!",
		resultTitleRest: "You created this GIF.",
		makeAnotherOneButton: "Make another one",
		downloadButton: "Download",
		generationError: "We couldn’t create the GIF. Please try again.",
		backLabel: "Go back"
	},
	ru: {
		uploadButton: "Выберите фото",
		uploadButtonBusy: "Подготавливаем…",
		uploadHelper: "JPG или PNG, не больше 10 MB.",
		uploadPrivacyNote: "Фото обрабатывается локально в браузере.<br />Ничего не загружается и не хранится.",
		invalidTypeError: "Загрузите изображение в формате JPG или PNG.",
		fileTooLargeError: "Файл должен быть не больше 10 MB.",
		noFaceError: "Мы не смогли определить лицо на этом фото. Попробуйте другое.",
		processingError: "Не удалось подготовить фото. Попробуйте ещё раз.",
		createGifButton: "Создать GIF",
		createGifButtonBusy: "Создаём…",
		uploadNewPhotoButton: "← Загрузить другое фото",
		resultTitleLead: "Браво!",
		resultTitleRest: "Гифка готова.",
		makeAnotherOneButton: "Сделать ещё одну",
		downloadButton: "Скачать",
		generationError: "Не удалось создать GIF. Попробуйте ещё раз.",
		backLabel: "Назад"
	}
};

const config: DealWithItAppConfig = {
	locale,
	backHref,
	dogGifSrc,
	glasses,
	copy: copy[locale]
};

const actionButtonBaseClass =
	"group relative inline-flex min-h-[56px] w-full cursor-pointer items-center justify-center overflow-hidden border-0 bg-[linear-gradient(180deg,rgba(255,255,255,0.07)_0%,rgba(255,255,255,0.02)_58%,rgba(255,255,255,0)_100%),rgba(22,22,22,0.56)] px-6 py-3 text-stone-100 shadow-[inset_0_1px_0_rgba(255,255,255,0.08),inset_0_-1px_0_rgba(255,255,255,0.03),inset_0_-6px_8px_-6px_rgba(0,0,0,0.56),0_8px_18px_rgba(0,0,0,0.16)] transition-[box-shadow,background-color,transform] duration-[100ms,100ms,100ms] ease-[ease,ease,ease] active:translate-y-[2px] active:bg-[linear-gradient(180deg,rgba(255,255,255,0.012)_0%,rgba(255,255,255,0.045)_100%),rgba(14,14,14,0.72)] active:shadow-[inset_0_1px_0_rgba(255,255,255,0.05),inset_0_2px_6px_rgba(0,0,0,0.22),inset_0_0_0_1px_rgba(255,255,255,0.02),0_0_0_rgba(0,0,0,0)] disabled:cursor-default disabled:opacity-40 disabled:pointer-events-none";

const primaryButtonClass =
	"group relative inline-flex min-h-[56px] w-full cursor-pointer items-center justify-center overflow-hidden border-0 bg-[linear-gradient(180deg,#ffd76a_0%,#feb601_100%)] px-6 py-3 text-[#101010] shadow-[inset_0_1px_0_rgba(255,255,255,0.28),inset_0_-1px_0_rgba(123,86,0,0.18),inset_0_-6px_8px_-6px_rgba(123,86,0,0.28),0_8px_18px_rgba(0,0,0,0.16)] transition-[box-shadow,background-color,transform] duration-[100ms,100ms,100ms] ease-[ease,ease,ease] active:translate-y-[2px] active:bg-[linear-gradient(180deg,#f6c53c_0%,#e7a901_100%)] active:shadow-[inset_0_1px_0_rgba(255,255,255,0.16),inset_0_2px_6px_rgba(123,86,0,0.18),inset_0_0_0_1px_rgba(255,255,255,0.02),0_0_0_rgba(0,0,0,0)] disabled:cursor-default disabled:opacity-40 disabled:pointer-events-none";

const secondaryButtonClass = actionButtonBaseClass;

const buttonChromeClass =
	"pointer-events-none absolute inset-0 p-px [background:linear-gradient(180deg,rgba(255,255,255,0.05)_0%,rgba(255,255,255,0.03)_55%,rgba(255,255,255,0)_100%)] [mask:linear-gradient(#000_0_0)_content-box,linear-gradient(#000_0_0)] [mask-composite:exclude] group-active:[background:linear-gradient(180deg,rgba(255,255,255,0.05)_0%,rgba(255,255,255,0.03)_55%,rgba(255,255,255,0.05)_100%)]";

const primaryButtonChromeClass =
	buttonChromeClass;

const buttonSheenClass =
	"pointer-events-none absolute bottom-[5px] left-[10px] right-[10px] h-px rounded-full bg-[linear-gradient(90deg,rgba(255,255,255,0)_0%,rgba(255,255,255,0.02)_10%,rgba(255,255,255,0.08)_50%,rgba(255,255,255,0.02)_90%,rgba(255,255,255,0)_100%)] group-active:opacity-[0.05]";

const buttonLabelClass =
	"relative inline-flex w-full items-center justify-center gap-2 font-['Press_Start_2P','IBM_Plex_Mono','SF_Mono','Cascadia_Mono','Menlo','Monaco',monospace] text-current text-[1.2rem] leading-[1.3] drop-shadow-[0_1px_0_rgba(255,255,255,0.12)]";

const primaryButtonLabelClass =
	`${buttonLabelClass}`;

const helperTextClass =
	"mt-2 max-w-[26rem] text-center text-sm leading-6 text-stone-950 dark:text-stone-50";

const privacyBubbleClass =
	"relative mt-6 max-w-[28rem] rounded-2xl border border-stone-400/80 bg-white/92 px-4 py-3 text-center text-[0.92rem] leading-6 text-stone-700 shadow-[0_10px_24px_rgba(28,25,23,0.08)] dark:border-stone-700/90 dark:bg-zinc-900/92 dark:text-stone-300";

const errorTextClass =
	"text-center text-sm leading-6 text-red-700 dark:text-red-300";

const glassesButtonClass = "dwi-glasses-choice";

const roundIconButtonClass = "dwi-back-button";
const stackedSecondaryButtonClass = "dwi-result-secondary-button";
---

<div class="dwi-root" data-deal-with-it-root>
	<script
		type="application/json"
		data-deal-with-it-config
		set:html={JSON.stringify(config)}
	></script>

	<a href={backHref} aria-label={copy[locale].backLabel} class="dwi-close-link">
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
			<path d="M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"></path>
			<path d="M18 6 6 18" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	</a>

	<section class="dwi-screen dwi-screen--upload" data-step-upload>
		<div class="dwi-upload-title-wrap" aria-hidden="true">
			<svg class="dwi-title-rays" viewBox="0 0 1600 700" preserveAspectRatio="xMidYMin slice">
				<defs>
					<linearGradient id="dwi-ray-pink" x1="0" y1="0" x2="0" y2="1">
						<stop offset="0%" stop-color="#ff4f9a" stop-opacity="0.95" />
						<stop offset="100%" stop-color="#ff4f9a" stop-opacity="0" />
					</linearGradient>
					<linearGradient id="dwi-ray-cyan" x1="0" y1="0" x2="0" y2="1">
						<stop offset="0%" stop-color="#6af6ff" stop-opacity="0.92" />
						<stop offset="100%" stop-color="#6af6ff" stop-opacity="0" />
					</linearGradient>
					<linearGradient id="dwi-ray-yellow" x1="0" y1="0" x2="0" y2="1">
						<stop offset="0%" stop-color="#ffe36d" stop-opacity="0.88" />
						<stop offset="100%" stop-color="#ffe36d" stop-opacity="0" />
					</linearGradient>
					<filter id="dwi-ray-glow" x="-20%" y="-20%" width="140%" height="140%">
						<feGaussianBlur stdDeviation="8" result="blur" />
						<feMerge>
							<feMergeNode in="blur" />
							<feMergeNode in="SourceGraphic" />
						</feMerge>
					</filter>
				</defs>
				<g filter="url(#dwi-ray-glow)">
					<polygon class="dwi-ray dwi-ray--g" points="800,0 190,700 300,700" fill="url(#dwi-ray-cyan)" />
					<polygon class="dwi-ray dwi-ray--a" points="800,0 335,700 445,700" fill="url(#dwi-ray-pink)" />
					<polygon class="dwi-ray dwi-ray--b" points="800,0 480,700 590,700" fill="url(#dwi-ray-yellow)" />
					<polygon class="dwi-ray dwi-ray--c" points="800,0 665,700 775,700" fill="url(#dwi-ray-cyan)" />
					<polygon class="dwi-ray dwi-ray--d" points="800,0 825,700 935,700" fill="url(#dwi-ray-pink)" />
					<polygon class="dwi-ray dwi-ray--e" points="800,0 1010,700 1120,700" fill="url(#dwi-ray-yellow)" />
					<polygon class="dwi-ray dwi-ray--f" points="800,0 1155,700 1265,700" fill="url(#dwi-ray-cyan)" />
					<polygon class="dwi-ray dwi-ray--h" points="800,0 1300,700 1410,700" fill="url(#dwi-ray-pink)" />
				</g>
				<circle class="dwi-ray-core" cx="800" cy="0" r="72" />
			</svg>
			<h1 class="dwi-title text-center text-[clamp(3.4rem,11vw,7.8rem)] uppercase leading-[0.78]">DEAL WITH IT</h1>
		</div>
		<div class="dwi-upload-stack">
			<img src={dogGifSrc} alt="" class="dwi-dog" data-dog-gif />
			<div class="dwi-upload-controls">
				<input data-upload-input class="dwi-upload-input" type="file" accept="image/jpeg,image/png,.jpg,.jpeg,.png" />
				<button data-upload-button class={`${primaryButtonClass} rounded-2xl border-b-[6px] border-b-[#8f6500] shadow-[inset_0_1px_0_rgba(255,255,255,0.28),inset_0_-1px_0_rgba(123,86,0,0.18),inset_0_-6px_8px_-6px_rgba(123,86,0,0.28),0_8px_18px_rgba(0,0,0,0.16)] hover:bg-[linear-gradient(180deg,#ffdf84_0%,#ffc526_100%)] hover:border-b-[#8f6500] hover:shadow-[inset_0_1px_0_rgba(255,255,255,0.32),inset_0_-1px_0_rgba(123,86,0,0.16),inset_0_-6px_8px_-6px_rgba(123,86,0,0.24),0_10px_22px_rgba(0,0,0,0.2)] active:border-b-[3px] active:shadow-[inset_0_1px_0_rgba(255,255,255,0.16),inset_0_2px_6px_rgba(123,86,0,0.18),inset_0_0_0_1px_rgba(255,255,255,0.02),0_0_0_rgba(0,0,0,0)]`} type="button">
					<span class={`${primaryButtonChromeClass} rounded-2xl`}></span>
					<span class={`${primaryButtonLabelClass} min-h-[64px] py-1.5 text-[1.35rem]`} data-upload-button-label>{copy[locale].uploadButton}</span>
				</button>
				<div class="dwi-upload-notes">
					<p class={helperTextClass}>{copy[locale].uploadHelper}</p>
					<p class={`${privacyBubbleClass} dwi-privacy-bubble`}>
						<span class="dwi-speech-tail"></span>
						<Fragment set:html={copy[locale].uploadPrivacyNote} />
					</p>
				</div>
				<p class={errorTextClass} data-upload-error hidden></p>
			</div>
		</div>
	</section>

	<section class="dwi-screen" data-step-editor hidden>
		<div class="dwi-editor-stack">
			<div class="dwi-editor-stage">
				<div class="dwi-slider-column dwi-slider-column--left">
					<span class="dwi-slider-midpoint" aria-hidden="true"></span>
					<input
						id="dwi-scale-slider"
						data-scale-slider
						class="dwi-vertical-slider"
						type="range"
						min="-100"
						max="100"
						step="1"
						value="0"
					/>
					<span class="dwi-slider-handle" aria-hidden="true">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="#000000" viewBox="0 0 256 256">
							<path d="M144,120v88a8,8,0,0,1-8,8H48a8,8,0,0,1-8-8V120a8,8,0,0,1,8-8h88A8,8,0,0,1,144,120Zm64,56a8,8,0,0,0-8,8v16H176a8,8,0,0,0,0,16h24a16,16,0,0,0,16-16V184A8,8,0,0,0,208,176Zm0-72a8,8,0,0,0-8,8v32a8,8,0,0,0,16,0V112A8,8,0,0,0,208,104Zm-8-64H184a8,8,0,0,0,0,16h16V72a8,8,0,0,0,16,0V56A16,16,0,0,0,200,40Zm-56,0H112a8,8,0,0,0,0,16h32a8,8,0,0,0,0-16ZM48,88a8,8,0,0,0,8-8V56H72a8,8,0,0,0,0-16H56A16,16,0,0,0,40,56V80A8,8,0,0,0,48,88Z"></path>
						</svg>
					</span>
				</div>
				<div class="dwi-preview-frame" data-preview-frame>
					<img data-preview-image class="dwi-preview-image" alt="" />
					<img data-preview-overlay class="dwi-preview-overlay" alt="" />
				</div>
				<div class="dwi-slider-column dwi-slider-column--right">
					<span class="dwi-slider-midpoint" aria-hidden="true"></span>
					<input
						id="dwi-rotation-slider"
						data-rotation-slider
						class="dwi-vertical-slider"
						type="range"
						min="-15"
						max="15"
						step="1"
						value="0"
					/>
					<span class="dwi-slider-handle" aria-hidden="true">
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="#000000" viewBox="0 0 256 256">
							<path d="M88,104H40a8,8,0,0,1-8-8V48a8,8,0,0,1,13.66-5.66L64,60.7a95.42,95.42,0,0,1,66-26.76h.53a95.36,95.36,0,0,1,67.07,27.33,8,8,0,0,1-11.18,11.44,79.52,79.52,0,0,0-55.89-22.77h-.45A79.48,79.48,0,0,0,75.35,72L93.66,90.34A8,8,0,0,1,88,104Zm128,48H168a8,8,0,0,0-5.66,13.66L180.65,184a79.48,79.48,0,0,1-54.72,22.09h-.45a79.52,79.52,0,0,1-55.89-22.77,8,8,0,1,0-11.18,11.44,95.36,95.36,0,0,0,67.07,27.33H126a95.42,95.42,0,0,0,66-26.76l18.36,18.36A8,8,0,0,0,224,208V160A8,8,0,0,0,216,152Z"></path>
						</svg>
					</span>
				</div>
			</div>
			<div class="dwi-glasses-grid">
				{
					glasses.map((item) => (
						<button
							type="button"
							class={glassesButtonClass}
							data-glasses-button={item.id}
							data-selected={item.id === glasses[0].id ? "true" : "false"}
						>
							<img src={item.src} alt="" />
						</button>
					))
				}
			</div>
			<div class="dwi-action-row dwi-action-row--editor">
				<button data-upload-new-button class={roundIconButtonClass} type="button" aria-label={copy[locale].uploadNewPhotoButton}>
					<span class="relative inline-flex items-center justify-center text-stone-100">
						<svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5">
							<path d="M14.5 5.5 8 12l6.5 6.5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2"></path>
						</svg>
					</span>
				</button>
				<button data-create-gif-button class={`${primaryButtonClass} h-[64px] min-h-[64px] rounded-2xl border-b-[6px] border-b-[#8f6500] shadow-[inset_0_1px_0_rgba(255,255,255,0.28),inset_0_-1px_0_rgba(123,86,0,0.18),inset_0_-6px_8px_-6px_rgba(123,86,0,0.28),0_8px_18px_rgba(0,0,0,0.16)] hover:bg-[linear-gradient(180deg,#ffdf84_0%,#ffc526_100%)] hover:border-b-[#8f6500] hover:shadow-[inset_0_1px_0_rgba(255,255,255,0.32),inset_0_-1px_0_rgba(123,86,0,0.16),inset_0_-6px_8px_-6px_rgba(123,86,0,0.24),0_10px_22px_rgba(0,0,0,0.2)] active:border-b-[3px] active:shadow-[inset_0_1px_0_rgba(255,255,255,0.16),inset_0_2px_6px_rgba(123,86,0,0.18),inset_0_0_0_1px_rgba(255,255,255,0.02),0_0_0_rgba(0,0,0,0)]`} type="button">
					<span class={`${primaryButtonChromeClass} rounded-2xl`}></span>
					<span class={`${primaryButtonLabelClass} min-h-[64px] py-1 text-[1.35rem]`} data-create-gif-button-label>{copy[locale].createGifButton}</span>
				</button>
			</div>
			<p class={`${errorTextClass} dwi-error--editor`} data-editor-error hidden></p>
		</div>
	</section>

	<section class="dwi-screen dwi-screen--result" data-step-result hidden>
		<div class="dwi-result-title-wrap" aria-hidden="true">
			<div class="dwi-result-title-block">
				<div class="dwi-title-stack dwi-result-title-stack">
					<span class="dwi-title-trail dwi-title-trail--c dwi-result-title-lead" aria-hidden="true">{copy[locale].resultTitleLead}</span>
					<span class="dwi-title-trail dwi-title-trail--b dwi-result-title-lead" aria-hidden="true">{copy[locale].resultTitleLead}</span>
					<span class="dwi-title-trail dwi-title-trail--a dwi-result-title-lead" aria-hidden="true">{copy[locale].resultTitleLead}</span>
					<h1 class="dwi-title dwi-result-title-lead">{copy[locale].resultTitleLead}</h1>
				</div>
				<p class="dwi-result-title-rest">{copy[locale].resultTitleRest}</p>
			</div>
		</div>
		<div class="dwi-result-stack">
			<div class="dwi-result-media-stack">
				<img data-result-image class="dwi-result-image" alt="" />
				<p class="dwi-result-meta" data-result-meta></p>
			</div>
			<div class="dwi-result-action-stack">
				<button data-download-button class={`${primaryButtonClass} rounded-2xl border-b-[6px] border-b-[#8f6500] shadow-[inset_0_1px_0_rgba(255,255,255,0.28),inset_0_-1px_0_rgba(123,86,0,0.18),inset_0_-6px_8px_-6px_rgba(123,86,0,0.28),0_8px_18px_rgba(0,0,0,0.16)] hover:bg-[linear-gradient(180deg,#ffdf84_0%,#ffc526_100%)] hover:border-b-[#8f6500] hover:shadow-[inset_0_1px_0_rgba(255,255,255,0.32),inset_0_-1px_0_rgba(123,86,0,0.16),inset_0_-6px_8px_-6px_rgba(123,86,0,0.24),0_10px_22px_rgba(0,0,0,0.2)] active:border-b-[3px] active:shadow-[inset_0_1px_0_rgba(255,255,255,0.16),inset_0_2px_6px_rgba(123,86,0,0.18),inset_0_0_0_1px_rgba(255,255,255,0.02),0_0_0_rgba(0,0,0,0)]`} type="button">
					<span class={`${primaryButtonChromeClass} rounded-2xl`}></span>
					<span class={`${primaryButtonLabelClass} min-h-[64px] py-1.5 text-[1.35rem]`} data-download-button-label>{copy[locale].downloadButton}</span>
				</button>
				<button data-restart-button class={stackedSecondaryButtonClass} type="button">
					<span class={buttonLabelClass}>{copy[locale].makeAnotherOneButton}</span>
				</button>
			</div>
		</div>
	</section>
</div>

<style>
	:root {
		--dwi-page-bg: #fafaf9;
		--dwi-page-fg: #1c1917;
		--dwi-control-color: #78716c;
		--dwi-control-hover: #44403c;
		--dwi-surface: rgba(255, 255, 255, 0.74);
		--dwi-surface-line: rgba(214, 211, 209, 0.88);
		--dwi-surface-strong: rgba(255, 255, 255, 0.92);
		--dwi-button-primary-bg: #1c1917;
		--dwi-button-primary-fg: #fafaf9;
		--dwi-button-secondary-bg: rgba(255, 255, 255, 0.78);
		--dwi-button-secondary-fg: #1c1917;
		--dwi-button-secondary-line: rgba(214, 211, 209, 0.92);
		--dwi-error: #b91c1c;
		--dwi-preview-size: 400px;
	}

	html.dark {
		--dwi-page-bg: #0c0a09;
		--dwi-page-fg: #f5f5f4;
		--dwi-control-color: #a8a29e;
		--dwi-control-hover: #e7e5e4;
		--dwi-surface: rgba(28, 25, 23, 0.82);
		--dwi-surface-line: rgba(68, 64, 60, 0.95);
		--dwi-surface-strong: rgba(28, 25, 23, 0.95);
		--dwi-button-primary-bg: #fafaf9;
		--dwi-button-primary-fg: #1c1917;
		--dwi-button-secondary-bg: rgba(28, 25, 23, 0.85);
		--dwi-button-secondary-fg: #f5f5f4;
		--dwi-button-secondary-line: rgba(87, 83, 78, 0.95);
		--dwi-error: #fca5a5;
	}

	.dwi-root {
		min-height: 100vh;
		background:
			radial-gradient(circle at top, rgba(120, 113, 108, 0.09), transparent 32%),
			var(--dwi-page-bg);
		color: var(--dwi-page-fg);
	}

	.dwi-close-link {
		position: fixed;
		top: 1.5rem;
		right: 1.5rem;
		z-index: 10;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3rem;
		height: 3rem;
		color: var(--dwi-control-color);
		text-decoration: none;
		transition:
			transform 220ms cubic-bezier(0.16, 1, 0.3, 1),
			color 180ms cubic-bezier(0.16, 1, 0.3, 1);
	}

	.dwi-close-link:hover {
		color: var(--dwi-control-hover);
		transform: scale(1.04);
	}

	.dwi-close-link:active {
		transform: scale(0.96);
	}

	.dwi-close-link:focus-visible {
		outline: none;
		color: var(--dwi-control-hover);
	}

	.dwi-close-link svg {
		width: clamp(1.45rem, 3vw, 2.1rem);
		height: clamp(1.45rem, 3vw, 2.1rem);
		flex: none;
		stroke-width: 1.2;
	}

	.dwi-screen {
		display: grid;
		min-height: 100vh;
		place-items: center;
		padding: 2rem 1.5rem;
	}

	.dwi-screen--upload {
		position: relative;
		overflow: hidden;
	}

	.dwi-screen--result {
		position: relative;
		overflow: hidden;
	}

	.dwi-screen[hidden] {
		display: none;
	}

	.dwi-upload-stack,
	.dwi-editor-stack,
	.dwi-result-stack {
		width: min(100%, 56rem);
		display: grid;
		justify-items: center;
	}

	.dwi-upload-stack {
		position: relative;
		z-index: 1;
		width: min(100%, 72rem);
		gap: 2.25rem;
	}

	.dwi-upload-title-wrap {
		position: absolute;
		left: 50%;
		top: 6.75rem;
		z-index: 1;
		display: flex;
		justify-content: center;
		width: min(100%, 86rem);
		pointer-events: none;
		transform: translateX(-50%);
		perspective: 1200px;
	}

	.dwi-title-rays {
		position: absolute;
		left: 50%;
		top: -7rem;
		width: min(100vw, 96rem);
		height: 56rem;
		transform: translateX(-50%);
		overflow: visible;
		pointer-events: none;
		mix-blend-mode: screen;
	}

	.dwi-title-stack {
		position: relative;
		display: grid;
		place-items: center;
		perspective: 1200px;
		transform-style: preserve-3d;
	}

	.dwi-ray {
		opacity: 0.82;
		animation: dwi-ray-flicker 3.8s ease-in-out infinite;
	}

	.dwi-ray--a { animation-delay: 0s; }
	.dwi-ray--b { animation-delay: 0.35s; }
	.dwi-ray--c { animation-delay: 0.7s; }
	.dwi-ray--d { animation-delay: 1.05s; }
	.dwi-ray--e { animation-delay: 1.4s; }
	.dwi-ray--f { animation-delay: 1.75s; }
	.dwi-ray--g { animation-delay: 2.1s; }
	.dwi-ray--h { animation-delay: 2.45s; }

	.dwi-ray-core {
		fill: #ffe36d;
		filter: blur(12px);
		opacity: 0.88;
		animation:
			dwi-ray-core-pulse 4.2s ease-in-out infinite alternate,
			dwi-ray-core-color 7.5s linear infinite;
	}

	.dwi-title {
		position: relative;
		margin: 0;
		white-space: nowrap;
		font-family: "Rubik Broken Fax", "IBM Plex Serif", serif;
		font-weight: 400;
		letter-spacing: 0.04em;
		color: transparent;
		background-image: linear-gradient(
			115deg,
			#ff3d81 0%,
			#ff9a2f 18%,
			#ffe36d 34%,
			#59f0ff 52%,
			#7d7dff 70%,
			#ff3d81 100%
		);
		background-size: 220% 220%;
		background-clip: text;
		-webkit-background-clip: text;
		transform-style: preserve-3d;
		animation:
			dwi-title-shift 5.5s linear infinite,
			dwi-title-drift 18s cubic-bezier(0.42, 0, 0.58, 1) infinite alternate;
	}

	.dwi-title-trail {
		position: absolute;
		inset: 0;
		display: grid;
		place-items: center;
		white-space: nowrap;
		font-family: "Rubik Broken Fax", "IBM Plex Serif", serif;
		font-weight: 400;
		letter-spacing: 0.04em;
		pointer-events: none;
	}

	.dwi-title-trail--a {
		z-index: 0;
		color: rgba(255, 61, 129, 0.92);
		transform: translate3d(0.08em, 0.1em, -18px) rotateZ(-0.5deg);
		animation: dwi-title-trail-a 18s cubic-bezier(0.42, 0, 0.58, 1) infinite alternate;
	}

	.dwi-title-trail--b {
		z-index: -1;
		color: rgba(89, 240, 255, 0.88);
		transform: translate3d(-0.08em, 0.14em, -34px) rotateZ(0.55deg);
		animation: dwi-title-trail-b 18s cubic-bezier(0.42, 0, 0.58, 1) infinite alternate;
	}

	.dwi-title-trail--c {
		z-index: -2;
		color: rgba(255, 227, 109, 0.76);
		transform: translate3d(0.02em, 0.18em, -48px) rotateZ(-0.35deg);
		animation: dwi-title-trail-c 18s cubic-bezier(0.42, 0, 0.58, 1) infinite alternate;
	}

	.dwi-editor-stack {
		gap: 1.25rem;
	}

	.dwi-result-stack {
		display: grid;
		gap: 2.25rem;
		width: min(100%, 34rem);
		position: relative;
		z-index: 1;
		padding-top: 11rem;
		justify-items: center;
	}

	.dwi-result-title-wrap {
		position: absolute;
		left: 50%;
		top: 4.75rem;
		z-index: 1;
		display: grid;
		justify-items: center;
		width: min(100%, 86rem);
		pointer-events: none;
		transform: translateX(-50%);
	}

	.dwi-result-title-block {
		display: grid;
		justify-items: center;
		gap: 3rem;
		text-align: center;
	}

	.dwi-result-title-lead,
	.dwi-result-title-rest {
		margin: 0;
	}

	.dwi-result-title-lead {
		font-size: clamp(3.4rem, 11vw, 7.8rem);
		line-height: 0.78;
		letter-spacing: 0.04em;
	}

	.dwi-result-title-rest {
		font-family: "Press Start 2P", "IBM Plex Mono", "SF Mono", "Cascadia Mono", "Menlo", "Monaco", monospace;
		font-size: clamp(1.55rem, 3.8vw, 2.1rem);
		font-weight: 400;
		line-height: 1.6;
		color: #f5f5f4;
		max-width: 28rem;
	}

	.dwi-result-media-stack {
		display: grid;
		justify-items: center;
		gap: 0.5rem;
	}

	.dwi-result-meta {
		margin: 0;
		max-width: 26rem;
		text-align: center;
		font-size: 0.875rem;
		line-height: 1.5rem;
		color: var(--dwi-page-fg);
	}

	.dwi-dog {
		display: block;
		width: min(100%, 14rem);
		height: auto;
	}

	.dwi-upload-controls {
		display: grid;
		width: min(100%, 28rem);
		justify-items: center;
		gap: 1.15rem;
	}

	.dwi-upload-notes {
		display: grid;
		justify-items: center;
		gap: 2rem;
	}

	.dwi-upload-input {
		position: absolute;
		opacity: 0;
		pointer-events: none;
	}

	.dwi-upload-controls p,
	.dwi-editor-stack > p {
		margin: 0;
	}

	.dwi-error--editor {
		max-width: 28rem;
	}

	.dwi-speech-tail {
		position: absolute;
		left: 50%;
		top: -0.5rem;
		bottom: auto;
		z-index: 1;
		width: 0.85rem;
		height: 0.85rem;
		border-top: 1px solid rgba(168, 162, 158, 0.8);
		border-right: 1px solid rgba(168, 162, 158, 0.8);
		background: inherit;
		transform: translateX(-50%) rotate(-45deg);
	}

	:global(.dark) .dwi-speech-tail {
		border-top-color: rgba(68, 64, 60, 0.9);
		border-right-color: rgba(68, 64, 60, 0.9);
	}

	.dwi-preview-frame {
		position: relative;
		width: var(--dwi-preview-size);
		height: var(--dwi-preview-size);
		aspect-ratio: 1;
		border-radius: 1.5rem;
		background: var(--dwi-surface);
		border: 1px solid var(--dwi-surface-line);
		box-shadow: 0 18px 48px rgba(28, 25, 23, 0.08);
		overflow: hidden;
		backdrop-filter: blur(10px);
		cursor: grab;
		touch-action: none;
	}

	.dwi-preview-frame[data-dragging="true"] {
		cursor: grabbing;
	}

	.dwi-editor-stage {
		display: grid;
		grid-template-columns: 2.75rem var(--dwi-preview-size) 2.75rem;
		align-items: center;
		gap: 0.75rem;
		width: fit-content;
		max-width: 100%;
		justify-content: center;
	}

	.dwi-slider-column {
		position: relative;
		width: 2.75rem;
		height: var(--dwi-preview-size);
		display: block;
		overflow: visible;
		--slider-progress: 0.5;
		--dwi-slider-handle-size: 3rem;
	}

	.dwi-slider-midpoint {
		position: absolute;
		left: 50%;
		top: 50%;
		width: 0.22rem;
		height: 0.22rem;
		border-radius: 999px;
		background: color-mix(in srgb, var(--dwi-control-color) 28%, transparent);
		transform: translate(-50%, -50%);
		pointer-events: none;
	}

	.dwi-vertical-slider {
		position: absolute;
		left: 50%;
		top: 50%;
		appearance: none;
		-webkit-appearance: none;
		width: var(--dwi-preview-size);
		height: 2.75rem;
		margin: 0;
		border: 0;
		background: transparent;
		transform: translate(-50%, -50%) rotate(-90deg);
		transform-origin: center center;
		cursor: ns-resize;
		overflow: visible;
		z-index: 2;
	}

	.dwi-vertical-slider::-webkit-slider-runnable-track {
		height: 0.7rem;
		border-radius: 999px;
		background: linear-gradient(
			270deg,
			color-mix(in srgb, var(--dwi-control-color) 44%, transparent) 0%,
			color-mix(in srgb, var(--dwi-control-color) 18%, transparent) 100%
		);
	}

	.dwi-vertical-slider::-webkit-slider-thumb {
		appearance: none;
		-webkit-appearance: none;
		width: var(--dwi-slider-handle-size);
		height: var(--dwi-slider-handle-size);
		margin-top: calc((0.7rem - var(--dwi-slider-handle-size)) / 2);
		border: 0;
		border-radius: 999px;
		background: transparent;
		box-shadow: none;
	}

	.dwi-vertical-slider::-moz-range-track {
		height: 0.7rem;
		border: 0;
		border-radius: 999px;
		background: linear-gradient(
			270deg,
			color-mix(in srgb, var(--dwi-control-color) 44%, transparent) 0%,
			color-mix(in srgb, var(--dwi-control-color) 18%, transparent) 100%
		);
	}


	.dwi-vertical-slider::-moz-range-thumb {
		width: var(--dwi-slider-handle-size);
		height: var(--dwi-slider-handle-size);
		border: 0;
		border-radius: 999px;
		background: transparent;
		box-shadow: none;
	}

	.dwi-slider-handle {
		position: absolute;
		left: 50%;
		top: calc((1 - var(--slider-progress)) * (100% - var(--dwi-slider-handle-size)) + (var(--dwi-slider-handle-size) / 2));
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: var(--dwi-slider-handle-size);
		height: var(--dwi-slider-handle-size);
		border-radius: 999px;
		background: linear-gradient(180deg, #ffffff 0%, #e7e5e4 100%);
		box-shadow:
			0 10px 22px rgba(28, 25, 23, 0.24),
			inset 0 1px 0 rgba(255, 255, 255, 0.9);
		transform: translate(-50%, -50%);
		pointer-events: none;
		z-index: 3;
	}

	.dwi-slider-handle svg {
		display: block;
		width: 1.25rem;
		height: 1.25rem;
	}

	.dwi-preview-image,
	.dwi-preview-overlay {
		position: absolute;
		inset: 0;
		display: block;
		width: 100%;
		height: 100%;
		object-fit: contain;
	}

	.dwi-preview-overlay {
		inset: auto;
		object-fit: fill;
		pointer-events: none;
		user-select: none;
		-webkit-user-drag: none;
		transform-origin: center;
	}

	.dwi-glasses-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.75rem;
		width: min(100%, calc(var(--dwi-preview-size) + 6.25rem));
	}

	.dwi-glasses-choice {
		appearance: none;
		-webkit-appearance: none;
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 64px;
		padding: 6px 8px;
		border: 0;
		border-radius: 14px;
		background-color: rgba(92, 86, 82, 0.38);
		box-shadow: none;
		cursor: pointer;
		transition:
			background-color 160ms ease,
			transform 120ms ease,
			box-shadow 120ms ease;
	}

	.dwi-glasses-choice::after {
		content: "";
		position: absolute;
		inset: 0;
		border: 1px solid rgba(245, 245, 244, 0.9);
		border-radius: inherit;
		opacity: 0;
		pointer-events: none;
		transition: opacity 140ms ease;
	}

	.dwi-glasses-choice:hover {
		background-color: rgba(108, 102, 98, 0.5);
		box-shadow: 0 8px 18px rgba(0, 0, 0, 0.12);
	}

	.dwi-glasses-choice[data-selected="true"] {
		background-color: rgba(108, 102, 98, 0.5);
		box-shadow: 0 8px 18px rgba(0, 0, 0, 0.12);
	}

	.dwi-glasses-choice[data-selected="true"]::after {
		opacity: 1;
	}

	.dwi-glasses-choice img {
		display: block;
		width: 100%;
		max-width: 56px;
		height: auto;
		position: relative;
	}

	.dwi-action-row {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem;
		width: min(100%, 36rem);
	}

	.dwi-result-action-stack {
		display: grid;
		gap: 1rem;
		width: min(100%, 30rem);
		margin-top: 0.75rem;
	}

	.dwi-action-row--editor {
		grid-template-columns: 64px minmax(0, 1fr);
		width: min(100%, calc(var(--dwi-preview-size) + 6.25rem));
	}

	.dwi-back-button {
		appearance: none;
		-webkit-appearance: none;
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 64px;
		min-width: 64px;
		height: 64px;
		min-height: 64px;
		padding: 0;
		border: 0;
		border-bottom: 6px solid #211d1b;
		border-radius: 1rem;
		background: linear-gradient(180deg, rgba(112, 106, 102, 0.58) 0%, rgba(86, 80, 76, 0.52) 100%);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.08),
			0 8px 18px rgba(0, 0, 0, 0.16);
		color: rgb(245 245 244);
		cursor: pointer;
		transition:
			background 160ms ease,
			box-shadow 120ms ease,
			transform 120ms ease;
	}

	.dwi-back-button:hover {
		background: linear-gradient(180deg, rgba(120, 114, 110, 0.62) 0%, rgba(94, 88, 84, 0.56) 100%);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.1),
			0 10px 22px rgba(0, 0, 0, 0.16);
	}

	.dwi-back-button:active {
		transform: translateY(2px);
		border-bottom-width: 3px;
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.06),
			0 0 0 rgba(0, 0, 0, 0);
	}

	.dwi-result-secondary-button {
		appearance: none;
		-webkit-appearance: none;
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		min-height: 64px;
		padding: 0 1.5rem;
		border: 0;
		border-bottom: 6px solid #211d1b;
		border-radius: 1rem;
		background: linear-gradient(180deg, rgba(112, 106, 102, 0.58) 0%, rgba(86, 80, 76, 0.52) 100%);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.08),
			0 8px 18px rgba(0, 0, 0, 0.16);
		color: rgb(245 245 244);
		cursor: pointer;
		transition:
			background 160ms ease,
			box-shadow 120ms ease,
			transform 120ms ease;
	}

	.dwi-result-secondary-button:hover {
		background: linear-gradient(180deg, rgba(120, 114, 110, 0.62) 0%, rgba(94, 88, 84, 0.56) 100%);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.1),
			0 10px 22px rgba(0, 0, 0, 0.16);
	}

	.dwi-result-secondary-button:active {
		transform: translateY(2px);
		border-bottom-width: 3px;
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.06),
			0 0 0 rgba(0, 0, 0, 0);
	}

	.dwi-result-image {
		display: block;
		width: 128px;
		height: 128px;
		image-rendering: auto;
	}

	@media (max-width: 40rem) {
		.dwi-screen {
			padding-inline: 1rem;
		}

		.dwi-upload-title-wrap {
			top: 4rem;
			width: min(100%, calc(100vw - 1rem));
		}

		.dwi-result-title-wrap {
			top: 3.25rem;
			width: min(100%, calc(100vw - 1rem));
		}

		.dwi-title {
			letter-spacing: 0.02em;
		}

		.dwi-result-stack {
			gap: 2rem;
			padding-top: 9rem;
		}

		.dwi-editor-stage {
			grid-template-columns: 1fr;
			gap: 1rem;
			width: min(100%, var(--dwi-preview-size));
		}

		.dwi-preview-frame {
			width: min(100%, var(--dwi-preview-size));
			height: auto;
		}

		.dwi-slider-column {
			width: min(100%, var(--dwi-preview-size));
			height: 2.75rem;
		}

		.dwi-slider-midpoint {
			left: 50%;
			top: 50%;
		}

		.dwi-vertical-slider {
			position: static;
			width: 100%;
			height: 2.5rem;
			transform: none;
			cursor: ew-resize;
		}

		.dwi-slider-handle {
			top: 50%;
			left: calc(var(--slider-progress) * (100% - var(--dwi-slider-handle-size)) + (var(--dwi-slider-handle-size) / 2));
			transform: translate(-50%, -50%);
		}

		.dwi-action-row {
			grid-template-columns: 1fr;
		}

		.dwi-action-row--editor {
			grid-template-columns: 4.5rem minmax(0, 1fr);
		}
	}

	@keyframes dwi-title-shift {
		0% {
			background-position: 0% 50%;
		}

		100% {
			background-position: 220% 50%;
		}
	}

	@keyframes dwi-title-drift {
		0% {
			transform: translate3d(-0.06rem, 0.04rem, 0) rotateZ(-0.45deg) rotateX(8deg) rotateY(-9deg) scale(0.992);
		}

		50% {
			transform: translate3d(0.08rem, -0.02rem, 0) rotateZ(0.4deg) rotateX(-6deg) rotateY(7deg) scale(1.012);
		}

		100% {
			transform: translate3d(-0.08rem, -0.03rem, 0) rotateZ(-0.5deg) rotateX(9deg) rotateY(-10deg) scale(0.995);
		}
	}

	@keyframes dwi-title-trail-a {
		0% {
			transform: translate3d(0.08em, 0.1em, -18px) rotateZ(-0.45deg);
			opacity: 0.5;
		}

		50% {
			transform: translate3d(0.12em, 0.14em, -20px) rotateZ(0.5deg);
			opacity: 0.68;
		}

		100% {
			transform: translate3d(0.1em, 0.08em, -19px) rotateZ(-0.55deg);
			opacity: 0.56;
		}
	}

	@keyframes dwi-title-trail-b {
		0% {
			transform: translate3d(-0.08em, 0.14em, -34px) rotateZ(0.45deg);
			opacity: 0.44;
		}

		50% {
			transform: translate3d(-0.14em, 0.18em, -38px) rotateZ(-0.55deg);
			opacity: 0.62;
		}

		100% {
			transform: translate3d(-0.1em, 0.12em, -35px) rotateZ(0.6deg);
			opacity: 0.48;
		}
	}

	@keyframes dwi-title-trail-c {
		0% {
			transform: translate3d(0.02em, 0.18em, -48px) rotateZ(-0.3deg);
			opacity: 0.38;
		}

		50% {
			transform: translate3d(0.06em, 0.24em, -52px) rotateZ(0.35deg);
			opacity: 0.52;
		}

		100% {
			transform: translate3d(0.04em, 0.2em, -50px) rotateZ(-0.4deg);
			opacity: 0.42;
		}
	}

	@keyframes dwi-ray-flicker {
		0% {
			opacity: 0.55;
		}

		18% {
			opacity: 0.88;
		}

		37% {
			opacity: 0.62;
		}

		58% {
			opacity: 1;
		}

		76% {
			opacity: 0.7;
		}

		100% {
			opacity: 0.9;
		}
	}

	@keyframes dwi-ray-core-pulse {
		0% {
			opacity: 0.58;
			transform: scale(0.92);
