---
import { shellWidthClass } from "../../lib/siteConfig";
import type { SocialLinkCopy } from "../../i18n/copy";

interface Props {
	isHomePage: boolean;
	socialLinks: SocialLinkCopy[];
	tagline: string;
}

const { isHomePage, socialLinks, tagline } = Astro.props;
---

<footer
	class:list={[
		"w-full border-t border-stone-200/80 dark:border-stone-800/80",
		isHomePage ? "mt-auto" : "mt-8"
	]}
>
	<div class:list={[
		"mx-auto flex w-full flex-col gap-4 text-sm text-stone-500 dark:text-stone-400 sm:flex-row sm:items-center sm:justify-between",
		isHomePage ? "pt-4 sm:pt-6" : "pt-6",
		shellWidthClass
		]}>
			<p class:list={[isHomePage ? "hidden sm:block" : "block"]}>
				{tagline}
			</p>
		<div
			class:list={[
				"flex items-center gap-1",
				isHomePage ? "justify-center gap-3 sm:gap-1" : ""
			]}
		>
			{
				socialLinks.map((item) => (
					<a
						href={item.href}
						target="_blank"
						rel="noreferrer"
						aria-label={item.label}
						data-footer-icon
						class:list={[
							"relative flex items-center justify-center text-stone-500 transition hover:text-stone-950",
							isHomePage ? "h-12 w-12 sm:h-10 sm:w-10" : "h-10 w-10"
						]}
					>
						{
							item.label === "LinkedIn" ? (
								<svg
									aria-hidden="true"
									viewBox="0 0 24 24"
									class:list={[
										"fill-current",
										isHomePage ? "h-6 w-6 sm:h-5 sm:w-5" : "h-5 w-5"
									]}
								>
									<path d="M6.94 8.5H3.56V20h3.38V8.5ZM5.25 3A1.97 1.97 0 0 0 3.28 5c0 1.08.88 1.94 1.94 1.94h.03A1.96 1.96 0 0 0 7.22 5 1.95 1.95 0 0 0 5.25 3Zm10.16 5.23c-1.8 0-2.6.99-3.06 1.69V8.5H8.97c.04.93 0 11.5 0 11.5h3.38v-6.42c0-.34.02-.68.13-.92.27-.68.88-1.38 1.9-1.38 1.34 0 1.88 1.03 1.88 2.54V20h3.38v-6.57c0-3.52-1.88-5.2-4.23-5.2Z"></path>
								</svg>
							) : item.label === "Telegram" ? (
								<svg
									aria-hidden="true"
									viewBox="0 0 24 24"
									class:list={[
										"fill-current",
										isHomePage ? "h-6 w-6 sm:h-5 sm:w-5" : "h-5 w-5"
									]}
								>
									<path d="M20.67 4.36c.52-.2 1 .13.83.93l-2.84 13.39c-.12.58-.45.72-.92.45l-4.33-3.2-2.09 2.01c-.23.23-.43.43-.87.43l.31-4.4 8.01-7.23c.35-.31-.08-.49-.53-.19l-9.9 6.24-4.26-1.33c-.93-.29-.95-.93.19-1.38l16.4-6.32Z"></path>
								</svg>
							) : (
								<svg
									aria-hidden="true"
									viewBox="0 0 24 24"
									class:list={[
										"fill-current",
										isHomePage ? "h-6 w-6 sm:h-5 sm:w-5" : "h-5 w-5"
									]}
								>
									<path d="M7.75 3h8.5A4.75 4.75 0 0 1 21 7.75v8.5A4.75 4.75 0 0 1 16.25 21h-8.5A4.75 4.75 0 0 1 3 16.25v-8.5A4.75 4.75 0 0 1 7.75 3Zm-.17 1.74A2.84 2.84 0 0 0 4.74 7.6v8.8a2.84 2.84 0 0 0 2.84 2.85h8.84a2.84 2.84 0 0 0 2.84-2.84V7.58a2.84 2.84 0 0 0-2.84-2.84H7.58Zm9.52 1.3a1.15 1.15 0 1 1 0 2.3 1.15 1.15 0 0 1 0-2.3ZM12 7.62A4.38 4.38 0 1 1 7.62 12 4.39 4.39 0 0 1 12 7.62Zm0 1.74A2.64 2.64 0 1 0 14.64 12 2.64 2.64 0 0 0 12 9.36Z"></path>
								</svg>
							)
						}
						<span class="tooltip tooltip--top" data-footer-tooltip aria-hidden="true">{item.label}</span>
					</a>
				))
			}
		</div>
	</div>
</footer>
