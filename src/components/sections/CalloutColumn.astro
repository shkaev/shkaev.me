---
import DisplayCallout from "../typography/DisplayCallout.astro";
import SectionBody from "../typography/SectionBody.astro";

interface Props {
	title: string;
	as?: string;
	titleAs?: string;
	class?: string;
	titleClass?: string;
	bodyClass?: string;
}

const {
	title,
	as = "div",
	titleAs = "p",
	class: className,
	titleClass,
	bodyClass
} = Astro.props;

const Tag = as;
---

<Tag class={className}>
	<DisplayCallout as={titleAs} class={titleClass}>{title}</DisplayCallout>
	<SectionBody class:list={["mt-3", bodyClass]}>
		<slot />
	</SectionBody>
</Tag>
