---
import CardTitle from "../typography/CardTitle.astro";
import SectionBody from "../typography/SectionBody.astro";

interface Props {
	as?: string;
	title: string;
	titleAs?: string;
	bodyVariant?: "body" | "lead";
	class?: string;
	titleClass?: string;
	bodyClass?: string;
}

const {
	as = "section",
	title,
	titleAs = "h2",
	bodyVariant = "body",
	class: className,
	titleClass,
	bodyClass
} = Astro.props;

const Tag = as;
const hasBodySlot = Astro.slots.has("default");
---

<Tag class:list={["mt-12 w-full", className]}>
	<CardTitle as={titleAs} class:list={["text-2xl sm:text-3xl", titleClass]}>
		{title}
	</CardTitle>
	{
		hasBodySlot && (
			bodyVariant === "lead" ? (
				<div class:list={["type-page-lead mt-6 space-y-0", bodyClass]}>
					<slot />
				</div>
			) : (
				<SectionBody class:list={["mt-6", bodyClass]}>
					<slot />
				</SectionBody>
			)
		)
	}
</Tag>
