---
import CardTitle from "../typography/CardTitle.astro";

interface Props {
	title: string;
	class?: string;
}

const {
	title,
	class: className
} = Astro.props;
---

<div class:list={["rounded-[2px] border-l border-stone-200 bg-transparent pl-6 pr-8 py-6", className]}>
	<CardTitle as="h3" class="text-[1.35rem] leading-[1.08] sm:text-[1.5rem]">
		{title}
	</CardTitle>
	<p class="mt-3 text-[0.98rem] leading-7 text-stone-700 sm:text-base">
		<slot />
	</p>
</div>
