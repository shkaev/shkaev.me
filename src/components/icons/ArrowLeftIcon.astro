---
interface Props {
	class?: string;
}

const { class: className = "h-5 w-5" } = Astro.props;
---

<svg
	aria-hidden="true"
	viewBox="0 0 24 24"
	class={className}
	fill="none"
	stroke="currentColor"
	stroke-linecap="round"
	stroke-linejoin="round"
	stroke-width="1.75"
>
	<path d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"></path>
</svg>
