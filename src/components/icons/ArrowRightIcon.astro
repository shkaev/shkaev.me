---
interface Props {
	class?: string;
}

const { class: className = "h-5 w-5" } = Astro.props;
---

<svg
	aria-hidden="true"
	viewBox="0 0 24 24"
	class={className}
	fill="none"
	stroke="currentColor"
	stroke-linecap="round"
	stroke-linejoin="round"
	stroke-width="1.75"
>
	<path d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
</svg>
