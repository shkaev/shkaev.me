---
interface Props {
	class?: string;
}

const { class: className = "h-5 w-5" } = Astro.props;
---

<svg
	aria-hidden="true"
	viewBox="0 0 24 24"
	class={className}
	fill="none"
	stroke="currentColor"
	stroke-linecap="round"
	stroke-linejoin="round"
	stroke-width="1.75"
>
	<path d="m8.25 4.5 7.5 7.5-7.5 7.5"></path>
</svg>
