---
import CardTitle from "./typography/CardTitle.astro";
import MicroLabel from "./typography/MicroLabel.astro";

interface TimelineItem {
	role: string;
	company: string;
	favicon?: string;
	href?: string;
	period: string;
	contractType: string;
	intro?: string;
	description?: string[];
}

interface Props {
	item: TimelineItem;
	getCompanyPlaceholder: (company: string) => string;
}

const { item, getCompanyPlaceholder } = Astro.props;
---

<article class="relative rounded-[1.75rem] border border-stone-200/80 bg-white/80 p-6 shadow-[0_1px_0_rgba(28,25,23,0.04)] backdrop-blur-sm">
	<span class="absolute left-[-2.375rem] top-[2.15rem] h-3 w-3 -translate-y-1/2 rounded-full bg-stone-400 sm:left-[-2.875rem]"></span>
	<div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
		<div class="min-w-0 flex-1">
			<p class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-stone-500">
				{
					item.href ? (
						<a
							href={item.href}
							target="_blank"
							rel="noreferrer"
							class="text-link inline-flex items-center gap-2"
						>
							{
								item.favicon ? (
									<img
										src={item.favicon}
										alt=""
										loading="lazy"
										class="h-4 w-4 rounded-sm"
									/>
								) : (
									<span class="flex h-4 w-4 items-center justify-center rounded-sm bg-stone-200 text-[0.55rem] font-semibold uppercase leading-none text-stone-600">
										{getCompanyPlaceholder(item.company)}
									</span>
								)
							}
							{item.company}
						</a>
					) : (
						<span class="inline-flex items-center gap-2">
							<span class="flex h-4 w-4 items-center justify-center rounded-sm bg-stone-200 text-[0.55rem] font-semibold uppercase leading-none text-stone-600">
								{getCompanyPlaceholder(item.company)}
							</span>
							<span>{item.company}</span>
						</span>
					)
				}
				<span class="text-stone-500">·</span>
				<span>{item.period}</span>
			</p>
			<CardTitle as="h2" class="mt-3 text-2xl sm:text-3xl">
				{item.role}
			</CardTitle>
		</div>
		<MicroLabel
			as="div"
			class="hidden shrink-0 whitespace-nowrap rounded-full bg-stone-100 px-3 py-1 tracking-[0.18em] sm:block"
		>
			{item.contractType}
		</MicroLabel>
	</div>
	{
		(item.intro || item.description) && (
			<div class="mt-1.5 w-full sm:mt-2.5">
				{
					item.intro && (
						<p class="text-sm leading-6 text-stone-700 sm:text-[0.95rem] sm:leading-7">
							{item.intro}
						</p>
					)
				}
				{
					item.description && (
						<ul class="mt-4 space-y-2 text-sm leading-6 text-stone-700 sm:text-[0.95rem] sm:leading-7">
							{
								item.description.map((point) => (
									<li class="flex gap-3">
										<span class="shrink-0 text-stone-500">·</span>
										<span>{point}</span>
									</li>
								))
							}
						</ul>
					)
				}
			</div>
		)
	}
</article>
